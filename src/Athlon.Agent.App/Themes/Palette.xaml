<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Aligned with report/html dark theme (zinc + sky/blue accent) -->
    <SolidColorBrush x:Key="Brush.AppBackground" Color="#101012" />
    <SolidColorBrush x:Key="Brush.Chrome" Color="#18181B" />
    <SolidColorBrush x:Key="Brush.Panel" Color="#262628" />
    <SolidColorBrush x:Key="Brush.PanelAlt" Color="#2A2A2D" />
    <SolidColorBrush x:Key="Brush.Composer" Color="#2A2A2D" />
    <SolidColorBrush x:Key="Brush.Border" Color="#3F3F46" />
    <SolidColorBrush x:Key="Brush.Text" Color="#F4F4F5" />
    <SolidColorBrush x:Key="Brush.SubtleText" Color="#A1A1AA" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#71717A" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#3F3F46" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#2563EB" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#1D4ED8" />
    <SolidColorBrush x:Key="Brush.UserBubble" Color="#1E3A5F" Opacity="0.86" />
    <SolidColorBrush x:Key="Brush.AssistantBubble" Color="#262628" />
    <SolidColorBrush x:Key="Brush.Success" Color="#10B981" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#E11D48" />
    <SolidColorBrush x:Key="Brush.DangerHover" Color="#BE123C" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FBBF24" />
    <SolidColorBrush x:Key="Brush.NavActiveBg" Color="#1E3A5F" />
    <SolidColorBrush x:Key="Brush.NavActiveText" Color="#93C5FD" />
    <SolidColorBrush x:Key="Brush.ToolThinkingBorder" Color="#6D28D9" />
    <SolidColorBrush x:Key="Brush.ToolThinkingBg" Color="#1E1B2E" />
    <SolidColorBrush x:Key="Brush.ToolThinkingText" Color="#DDD6FE" />
    <SolidColorBrush x:Key="Brush.ToolSuccessBorder" Color="#059669" />
    <SolidColorBrush x:Key="Brush.ToolSuccessBg" Color="#142A22" />
    <SolidColorBrush x:Key="Brush.ToolSuccessText" Color="#6EE7B7" />
    <SolidColorBrush x:Key="Brush.ToolFailureBorder" Color="#E11D48" />
    <SolidColorBrush x:Key="Brush.ToolFailureBg" Color="#2A1418" />
    <SolidColorBrush x:Key="Brush.ToolFailureText" Color="#FDA4AF" />
    <SolidColorBrush x:Key="Brush.IconBadgeStart" Color="#0284C7" />
    <SolidColorBrush x:Key="Brush.IconBadgeEnd" Color="#7DD3FC" />

    <!-- Semantic hover / selection -->
    <SolidColorBrush x:Key="Brush.HoverNeutral" Color="#27272A" />
    <SolidColorBrush x:Key="Brush.HoverNeutralAlt" Color="#2F2F34" />
    <SolidColorBrush x:Key="Brush.HoverActive" Color="#254766" />
    <SolidColorBrush x:Key="Brush.HoverTool" Color="#242237" />
    <SolidColorBrush x:Key="Brush.HoverToolPressed" Color="#2C2942" />
    <SolidColorBrush x:Key="Brush.HoverSurface" Color="#2A2A2D" />
    <SolidColorBrush x:Key="Brush.HoverSurfacePressed" Color="#33333A" />
    <SolidColorBrush x:Key="Brush.SelectionActive" Color="#1E3A5F" />
    <SolidColorBrush x:Key="Brush.SelectionInactive" Color="#243A55" />
    <SolidColorBrush x:Key="Brush.SelectionBorder" Color="#2F5C8E" />

    <!-- Code / markdown -->
    <SolidColorBrush x:Key="Brush.CodeBackground" Color="#202023" />
    <SolidColorBrush x:Key="Brush.CodeBackgroundAlt" Color="#27272A" />
    <SolidColorBrush x:Key="Brush.CodeForeground" Color="#F1F5F9" />
    <SolidColorBrush x:Key="Brush.CodeBorder" Color="#1E293B" />
    <SolidColorBrush x:Key="Brush.CodeHighlightBlue" Color="#93C5FD" />
    <SolidColorBrush x:Key="Brush.TableBorder" Color="#52525B" />

    <!-- Menus / overlays -->
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#27272A" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#3F3F46" />
    <SolidColorBrush x:Key="Brush.ToastBackground" Color="#0F172A" />
    <SolidColorBrush x:Key="Brush.ToastBorder" Color="#334155" />
    <SolidColorBrush x:Key="Brush.PreviewContentBackground" Color="White" />

    <SolidColorBrush x:Key="Brush.ScrollThumb" Color="#9494A8" Opacity="0.55" />

    <LinearGradientBrush x:Key="Brush.ChatBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#141416" Offset="0" />
        <GradientStop Color="#101012" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.IconBadge" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E0F2FE" Offset="0" />
        <GradientStop Color="#0284C7" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
