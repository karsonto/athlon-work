<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.AppBackground" Color="#0D0F12" />
    <SolidColorBrush x:Key="Brush.Panel" Color="#15181D" />
    <SolidColorBrush x:Key="Brush.PanelAlt" Color="#1E232B" />
    <SolidColorBrush x:Key="Brush.Border" Color="#2B313A" />
    <SolidColorBrush x:Key="Brush.Text" Color="#E8EAED" />
    <SolidColorBrush x:Key="Brush.SubtleText" Color="#8E98A8" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#5B8CFF" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#C7782A" />

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="Background" Value="#232832" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="Background" Value="#181C22" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
</ResourceDictionary>
