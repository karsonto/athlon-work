<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Knowledge 导航图标 -->
    <Style x:Key="KnowledgeNavIconStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="28" Height="28">
                            <Border CornerRadius="9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF8B5CF6" Offset="0" />
                                        <GradientStop Color="#FF06B6D4" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Path Data="M7,7.2 C9.3,5.8 11.5,5.8 13.6,7.1 L13.6,21.6 C11.6,20.3 9.4,20.2 7,21.5 Z"
                                  Fill="#FFFFFFFF"
                                  Opacity="0.95" />
                            <Path Data="M14.4,7.1 C16.5,5.8 18.7,5.8 21,7.2 L21,21.5 C18.6,20.2 16.4,20.3 14.4,21.6 Z"
                                  Fill="#FFE0F2FE"
                                  Opacity="0.96" />
                            <Path Data="M9,10.1 L12,9.4 M9,13 L12,12.5 M16,9.4 L19,10.1 M16,12.5 L19,13"
                                  Stroke="#FF0EA5E9"
                                  StrokeThickness="0.9"
                                  Opacity="0.75" />
                            <Path Data="M20.6,4.5 L21.5,6.3 L23.5,7.2 L21.5,8 L20.6,9.8 L19.8,8 L17.8,7.2 L19.8,6.3 Z"
                                  Fill="#FFFDE68A" />
                        </Grid>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Schedule 导航图标 -->
    <Style x:Key="ScheduleNavIconStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="28" Height="28">
                            <Border CornerRadius="14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF97316" Offset="0" />
                                        <GradientStop Color="#FFEC4899" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Ellipse Width="17"
                                     Height="17"
                                     Stroke="#FFFFFFFF"
                                     StrokeThickness="2.2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Path Data="M14,9.3 L14,14.6 L18,17"
                                  Stroke="#FFFFFFFF"
                                  StrokeThickness="2.1" />
                            <Path Data="M8.2,5.8 L6.6,4.2 M19.8,5.8 L21.4,4.2"
                                  Stroke="#FFFFF7ED"
                                  StrokeThickness="1.8"
                                  Opacity="0.9" />
                            <Ellipse Width="3.2"
                                     Height="3.2"
                                     Fill="#FFFFF7ED"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
