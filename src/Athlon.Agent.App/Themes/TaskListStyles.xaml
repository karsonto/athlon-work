<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels">

    <Style x:Key="SessionTaskPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.PanelAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="SessionTaskItemContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="2,4" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ShouldPlayCompletionAnimation}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CompletionHighlight"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="0.85"
                                             Duration="0:0:0.15"
                                             AutoReverse="True" />
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorHost"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.2">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut" />
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorHost"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.2">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut" />
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="CompletedCheck"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskPendingRingStyle" TargetType="Ellipse">
        <Setter Property="Stroke" Value="{DynamicResource Brush.Border}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsPending}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskInProgressDotStyle" TargetType="Ellipse">
        <Setter Property="Fill" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsInProgress}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskCompletedCircleStyle" TargetType="Ellipse">
        <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskCompletedCheckStyle" TargetType="Path">
        <Setter Property="Data" Value="M4,8 L7,11 L12,5" />
        <Setter Property="Stroke" Value="{DynamicResource Brush.OnSuccess}" />
        <Setter Property="StrokeThickness" Value="1.6" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
                <Setter Property="Opacity" Value="1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskCancelledMarkStyle" TargetType="Path">
        <Setter Property="Data" Value="M5,5 L11,11 M11,5 L5,11" />
        <Setter Property="Stroke" Value="{DynamicResource Brush.SubtleText}" />
        <Setter Property="StrokeThickness" Value="1.4" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionTaskContentTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                <Setter Property="TextDecorations" Value="Strikethrough" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Brush.SubtleText}" />
                <Setter Property="TextDecorations" Value="Strikethrough" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type vm:SessionTaskItemViewModel}">
        <Border Style="{StaticResource SessionTaskItemContainerStyle}">
            <Grid>
                <Border x:Name="CompletionHighlight"
                        Background="{DynamicResource Brush.SuccessSubtle}"
                        CornerRadius="6"
                        Opacity="0"
                        IsHitTestVisible="False" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid x:Name="IndicatorHost"
                          Width="16"
                          Height="16"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Margin="0,2,0,0"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Ellipse Style="{StaticResource SessionTaskPendingRingStyle}" />
                        <Ellipse Style="{StaticResource SessionTaskInProgressDotStyle}" />
                        <Ellipse Style="{StaticResource SessionTaskCompletedCircleStyle}" />
                        <Path x:Name="CompletedCheck" Style="{StaticResource SessionTaskCompletedCheckStyle}" />
                        <Path Style="{StaticResource SessionTaskCancelledMarkStyle}" />
                    </Grid>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Content}"
                               Style="{StaticResource SessionTaskContentTextStyle}" />
                </Grid>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
