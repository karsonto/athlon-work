<UserControl x:Class="Athlon.Agent.App.Controls.ThemeToggleIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="18"
             Height="18"
             Foreground="{DynamicResource Brush.SubtleText}"
             Focusable="False"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid Width="18" Height="18">
        <!--
          Moon: two-circle exclude, center (9,9) to match sidebar optical mid-line.
          Slightly smaller mass than before so it doesn't sit above the panel icon.
        -->
        <Viewbox x:Name="MoonIcon"
                 Width="18"
                 Height="18"
                 Stretch="Uniform">
            <Canvas Width="18" Height="18">
                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Path.Data>
                        <CombinedGeometry GeometryCombineMode="Exclude">
                            <CombinedGeometry.Geometry1>
                                <EllipseGeometry Center="8.2,9.5" RadiusX="5.4" RadiusY="5.4" />
                            </CombinedGeometry.Geometry1>
                            <CombinedGeometry.Geometry2>
                                <EllipseGeometry Center="10.85,8.0" RadiusX="4.35" RadiusY="4.35" />
                            </CombinedGeometry.Geometry2>
                        </CombinedGeometry>
                    </Path.Data>
                </Path>
            </Canvas>
        </Viewbox>

        <!-- Sun: outline + rays, same center line -->
        <Viewbox x:Name="SunIcon"
                 Width="18"
                 Height="18"
                 Stretch="Uniform"
                 Visibility="Collapsed">
            <Canvas Width="18" Height="18">
                <Ellipse Canvas.Left="5.4"
                         Canvas.Top="5.4"
                         Width="7.2"
                         Height="7.2"
                         Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         StrokeThickness="1.2"
                         Fill="Transparent" />
                <Line X1="9" Y1="1.7" X2="9" Y2="3.55"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="9" Y1="14.45" X2="9" Y2="16.3"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="1.7" Y1="9" X2="3.55" Y2="9"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="14.45" Y1="9" X2="16.3" Y2="9"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="3.6" Y1="3.6" X2="4.9" Y2="4.9"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="13.1" Y1="13.1" X2="14.4" Y2="14.4"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="14.4" Y1="3.6" X2="13.1" Y2="4.9"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                <Line X1="4.9" Y1="13.1" X2="3.6" Y2="14.4"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
