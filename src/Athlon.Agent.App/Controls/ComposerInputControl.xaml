<UserControl x:Class="Athlon.Agent.App.Controls.ComposerInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="600">
    <Grid>
        <TextBox x:Name="ComposerTextBox"
                 Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ComposerTextBoxStyle}"
                 TextChanged="ComposerTextBox_OnTextChanged"
                 PreviewKeyDown="ComposerTextBox_OnPreviewKeyDown" />
        <TextBlock x:Name="PlaceholderText"
                   Text="{loc:Localize Key=Chat_ComposerPlaceholder}"
                   Foreground="{DynamicResource Brush.SubtleText}"
                   Margin="12,12,0,0"
                   IsHitTestVisible="False"
                   FontSize="14"
                   Visibility="Visible" />
        <Popup IsOpen="{Binding IsAtCompletionOpen, Mode=OneWay}"
               PlacementTarget="{Binding ElementName=ComposerTextBox}"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource Brush.Panel}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6"
                    MinWidth="340"
                    MaxWidth="560"
                    MaxHeight="240">
                <ListBox x:Name="AtCompletionListBox"
                         ItemsSource="{Binding AtCompletionItems}"
                         SelectedIndex="{Binding SelectedAtCompletionIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Focusable="False"
                         KeyboardNavigation.DirectionalNavigation="Contained"
                         MouseDoubleClick="AtCompletionListBox_OnMouseDoubleClick"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemContainerStyle="{StaticResource CompletionListBoxItemStyle}">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAtCompletionOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,2"
                                        Margin="0,0,8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush.AtCompletionFileBadgeBg}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.AtCompletionFileBadgeBorder}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="技能">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.AtCompletionSkillBadgeBg}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.AtCompletionSkillBadgeBorder}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Type}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.AtCompletionFileBadgeText}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="技能">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.AtCompletionSkillBadgeText}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SecondaryText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</UserControl>
