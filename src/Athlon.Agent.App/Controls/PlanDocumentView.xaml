<UserControl x:Class="Athlon.Agent.App.Controls.PlanDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <wv2:WebView2 x:Name="PlanWebView"
                      Grid.Row="0"
                      DefaultBackgroundColor="Transparent" />
        <Button Grid.Row="1"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch"
                Content="{loc:Localize Key=Harness_ConfirmPlan}"
                Command="{Binding ConfirmPlanCommand}"
                Style="{StaticResource NavBottomButtonStyle}" />
    </Grid>
</UserControl>
