<UserControl x:Class="Athlon.Agent.App.Controls.RightSidebarToggleIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="18"
             Height="18"
             Foreground="{DynamicResource Brush.SubtleText}"
             Focusable="False">
    <Viewbox Width="18" Height="18" Stretch="Uniform">
        <Canvas Width="18" Height="18">
            <Rectangle Canvas.Left="1"
                       Canvas.Top="2"
                       Width="16"
                       Height="14"
                       RadiusX="2.5"
                       RadiusY="2.5"
                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       StrokeThickness="1.15"
                       Fill="Transparent" />
            <Rectangle x:Name="PanelFill"
                       Canvas.Left="11"
                       Canvas.Top="4"
                       Width="4.5"
                       Height="10"
                       RadiusX="1"
                       RadiusY="1"
                       Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Canvas>
    </Viewbox>
</UserControl>
