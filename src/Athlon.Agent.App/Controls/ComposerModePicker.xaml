<UserControl x:Class="Athlon.Agent.App.Controls.ComposerModePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
             xmlns:harness="clr-namespace:Athlon.Agent.Core.Harness;assembly=Athlon.Agent.Core">
    <UserControl.Resources>
        <!-- Shared monoline icons (16×16), stroke binds to parent Foreground via TemplatedParent or Tag -->
        <Style x:Key="ModeIconStroke" TargetType="Shape">
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="SnapsToDevicePixels" Value="False" />
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal">
        <Button x:Name="ModePickerButton"
                Command="{Binding ComposerHarness.ToggleModePickerCommand}"
                ToolTip="{Binding ComposerHarness.HarnessButtonToolTip}"
                VerticalAlignment="Center">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource ComposerModePillButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                     Value="{x:Static harness:SessionAgentMode.Coding}">
                            <Setter Property="Background" Value="{DynamicResource Brush.ModeCodingBg}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ModeCodingBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.ModeCodingForeground}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                     Value="{x:Static harness:SessionAgentMode.Plan}">
                            <Setter Property="Background" Value="{DynamicResource Brush.ModePlanBg}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ModePlanBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.ModePlanForeground}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                     Value="{x:Static harness:SessionAgentMode.Ask}">
                            <Setter Property="Background" Value="{DynamicResource Brush.ModeAskBg}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ModeAskBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.ModeAskForeground}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel Orientation="Horizontal">
                <Grid Width="15" Height="15" Margin="0,0,7,0" VerticalAlignment="Center">
                    <!-- Agent ∞ -->
                    <TextBlock Text="∞"
                               FontSize="14"
                               FontWeight="Normal"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-1,0,0"
                               Opacity="0.95"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Coding}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Plan}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Ask}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Coding sliders -->
                    <Viewbox Width="14" Height="14" Stretch="Uniform">
                        <Viewbox.Style>
                            <Style TargetType="Viewbox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Coding}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Viewbox.Style>
                        <Canvas Width="16" Height="16">
                            <Line X1="1.5" Y1="5" X2="14.5" Y2="5"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Ellipse Canvas.Left="9.5" Canvas.Top="2.75" Width="4.5" Height="4.5"
                                     Style="{StaticResource ModeIconStroke}"
                                     Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                     Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Background}" />
                            <Line X1="1.5" Y1="11" X2="14.5" Y2="11"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Ellipse Canvas.Left="2" Canvas.Top="8.75" Width="4.5" Height="4.5"
                                     Style="{StaticResource ModeIconStroke}"
                                     Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                     Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Background}" />
                        </Canvas>
                    </Viewbox>
                    <!-- Plan document -->
                    <Viewbox Width="13" Height="13" Stretch="Uniform">
                        <Viewbox.Style>
                            <Style TargetType="Viewbox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Plan}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Viewbox.Style>
                        <Canvas Width="16" Height="16">
                            <Path Data="M4,1.5 H10 L13.5,5 V14.5 H4 Z M10,1.5 V5 H13.5"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Line X1="6" Y1="7.5" X2="11.5" Y2="7.5"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Line X1="6" Y1="10" X2="11.5" Y2="10"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Line X1="6" Y1="12.5" X2="10" Y2="12.5"
                                  Style="{StaticResource ModeIconStroke}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                        </Canvas>
                    </Viewbox>
                    <!-- Ask bubble -->
                    <Viewbox Width="13" Height="13" Stretch="Uniform">
                        <Viewbox.Style>
                            <Style TargetType="Viewbox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Ask}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Viewbox.Style>
                        <Path Data="M3,2.5 H12.5 A1.5,1.5 0 0 1 14,4 V9.5 A1.5,1.5 0 0 1 12.5,11 H7.2 L4.2,14.2 V11 H3 A1.5,1.5 0 0 1 1.5,9.5 V4 A1.5,1.5 0 0 1 3,2.5 Z"
                              Style="{StaticResource ModeIconStroke}"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                    </Viewbox>
                </Grid>
                <TextBlock Text="{Binding ComposerHarness.HarnessPickerLabel}"
                           FontSize="12.5"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                <Path Data="M0,0 L3.5,3.5 L7,0"
                      Width="7"
                      Height="4"
                      Stretch="Uniform"
                      Margin="6,1,0,0"
                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1.4"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Fill="Transparent"
                      VerticalAlignment="Center"
                      Opacity="0.75" />
            </StackPanel>
        </Button>

        <Popup PlacementTarget="{Binding ElementName=ModePickerButton}"
               Placement="Top"
               HorizontalOffset="-2"
               VerticalOffset="-6"
               IsOpen="{Binding ComposerHarness.IsModePickerOpen, Mode=TwoWay}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource Brush.MenuBackground}"
                    BorderBrush="{DynamicResource Brush.ComposerBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="5"
                    MinWidth="212"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="8"
                                      Direction="270"
                                      Opacity="0.45"
                                      Color="#000000" />
                </Border.Effect>
                <StackPanel>
                    <!-- Agent -->
                    <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                            CommandParameter="{x:Static harness:SessionAgentMode.Agent}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ComposerModeMenuItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Agent}">
                                        <Setter Property="Background" Value="{DynamicResource Brush.MenuHover}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="∞"
                                       FontSize="15"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="2,0,0,1"
                                       Opacity="0.92"
                                       Foreground="{DynamicResource Brush.Text}" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Localize Key=Harness_Mode_Agent}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="✓"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="16,0,2,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextSecondary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                         Value="{x:Static harness:SessionAgentMode.Agent}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Plan -->
                    <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                            CommandParameter="{x:Static harness:SessionAgentMode.Plan}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ComposerModeMenuItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Plan}">
                                        <Setter Property="Background" Value="{DynamicResource Brush.MenuHover}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0"
                                     Width="14"
                                     Height="14"
                                     HorizontalAlignment="Left"
                                     Margin="1,0,0,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M4,1.5 H10 L13.5,5 V14.5 H4 Z M10,1.5 V5 H13.5"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                    <Line X1="6" Y1="7.5" X2="11.5" Y2="7.5"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                    <Line X1="6" Y1="10" X2="11.5" Y2="10"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                    <Line X1="6" Y1="12.5" X2="10" Y2="12.5"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Localize Key=Harness_Mode_Plan}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="✓"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="16,0,2,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextSecondary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                         Value="{x:Static harness:SessionAgentMode.Plan}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Coding -->
                    <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                            CommandParameter="{x:Static harness:SessionAgentMode.Coding}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ComposerModeMenuItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Coding}">
                                        <Setter Property="Background" Value="{DynamicResource Brush.MenuHover}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0"
                                     Width="15"
                                     Height="15"
                                     HorizontalAlignment="Left"
                                     Margin="1,0,0,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="16" Height="16">
                                    <Line X1="1.5" Y1="5" X2="14.5" Y2="5"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                    <Ellipse Canvas.Left="9.5" Canvas.Top="2.75" Width="4.5" Height="4.5"
                                             Style="{StaticResource ModeIconStroke}"
                                             Stroke="{DynamicResource Brush.Text}"
                                             Fill="{DynamicResource Brush.MenuBackground}" />
                                    <Line X1="1.5" Y1="11" X2="14.5" Y2="11"
                                          Style="{StaticResource ModeIconStroke}"
                                          Stroke="{DynamicResource Brush.Text}" />
                                    <Ellipse Canvas.Left="2" Canvas.Top="8.75" Width="4.5" Height="4.5"
                                             Style="{StaticResource ModeIconStroke}"
                                             Stroke="{DynamicResource Brush.Text}"
                                             Fill="{DynamicResource Brush.MenuBackground}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Localize Key=Harness_Mode_Coding}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="✓"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="16,0,2,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextSecondary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                         Value="{x:Static harness:SessionAgentMode.Coding}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Ask -->
                    <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                            CommandParameter="{x:Static harness:SessionAgentMode.Ask}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ComposerModeMenuItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                 Value="{x:Static harness:SessionAgentMode.Ask}">
                                        <Setter Property="Background" Value="{DynamicResource Brush.MenuHover}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0"
                                     Width="14"
                                     Height="14"
                                     HorizontalAlignment="Left"
                                     Margin="1,0,0,0"
                                     VerticalAlignment="Center">
                                <Path Data="M3,2.5 H12.5 A1.5,1.5 0 0 1 14,4 V9.5 A1.5,1.5 0 0 1 12.5,11 H7.2 L4.2,14.2 V11 H3 A1.5,1.5 0 0 1 1.5,9.5 V4 A1.5,1.5 0 0 1 3,2.5 Z"
                                      Style="{StaticResource ModeIconStroke}"
                                      Stroke="{DynamicResource Brush.Text}" />
                            </Viewbox>
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Localize Key=Harness_Mode_Ask}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="✓"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="16,0,2,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextSecondary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}"
                                                         Value="{x:Static harness:SessionAgentMode.Ask}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
