<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:app="clr-namespace:Athlon.Agent.App"
        xmlns:behaviors="clr-namespace:Athlon.Agent.App.Behaviors"
        xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
        xmlns:views="clr-namespace:Athlon.Agent.App.Views"
        xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{loc:Localize Key=Common_ProductName}"
        Icon="/Assets/app-icon.ico"
        Height="768"
        Width="1366"
        MinHeight="720"
        MinWidth="1100"
        Background="{DynamicResource Brush.AppBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleNavigationSidebarCommand}" />
        <KeyBinding Key="B" Modifiers="Control+Alt" Command="{Binding ToggleContextSidebarCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveActiveEditorCommand}" />
    </Window.InputBindings>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{x:Static app:AppLayoutMetrics.WindowChromeRowHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationSidebarColumn"
                              Width="280"
                              MinWidth="180"
                              MaxWidth="480" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ContextSidebarColumn"
                              Width="320"
                              MinWidth="220"
                              MaxWidth="560" />
        </Grid.ColumnDefinitions>

        <!-- Window chrome (minimize / maximize / close only) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource Brush.AppBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <i:Interaction.Behaviors>
                <behaviors:WindowChromeBehavior MaximizeRestoreButton="{Binding ElementName=MaximizeRestoreButton}" />
            </i:Interaction.Behaviors>
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,0">
                    <Image Source="/Assets/app-icon-48.png"
                           Width="16"
                           Height="16"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <Menu Style="{StaticResource TitleBarMenuStyle}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True"
                          VerticalAlignment="Stretch">
                        <MenuItem Header="{loc:Localize Key=Common_Help}"
                                  Style="{StaticResource TitleBarTopMenuItemStyle}">
                            <MenuItem Header="{loc:Localize Key=Common_About}"
                                      Click="HelpAboutMenuItem_OnClick" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,2,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button ToolTip="{loc:Localize Key=Common_Minimize}"
                            ContentTemplate="{StaticResource WindowCaptionMinimizeIconTemplate}"
                            Style="{StaticResource WindowCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="Minimize" />
                        </i:Interaction.Behaviors>
                    </Button>
                    <Button x:Name="MaximizeRestoreButton"
                            ToolTip="{loc:Localize Key=Common_Maximize}"
                            ContentTemplate="{StaticResource WindowCaptionMaximizeIconTemplate}"
                            Style="{StaticResource WindowCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="MaximizeRestore" />
                        </i:Interaction.Behaviors>
                    </Button>
                    <Button ToolTip="{loc:Localize Key=Common_Close}"
                            ContentTemplate="{StaticResource WindowCaptionCloseIconTemplate}"
                            Style="{StaticResource WindowCloseCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="Close" />
                        </i:Interaction.Behaviors>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left sidebar — session list (full height under caption) -->
        <views:NavigationSidebarView x:Name="NavigationSidebarPanel"
                                     Grid.Row="1"
                                     Grid.RowSpan="2"
                                     Grid.Column="0" />

        <!-- Main column: chat / settings + composer + footer -->
        <!-- Main column: lazy-loaded pages -->
        <ContentControl x:Name="PageHost"
                          Grid.Row="1"
                          Grid.Column="1"
                          Content="{Binding CurrentPageView}" />

        <!-- Context panel (full height under caption) -->
        <Border x:Name="ContextSidebarPanel"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="2"
                ClipToBounds="True"
                Background="{DynamicResource Brush.ChatBackground}"
                BorderThickness="0">
            <views:ContextSidebarView />
        </Border>

        <!-- 底部状态栏：仅主列，与聊天区同色贯通 -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{DynamicResource Brush.ChatBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0"
                Padding="24,8"
                MinHeight="36">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Sidebar.LocalModelStatus, StringFormat=● {0}}"
                           Foreground="{DynamicResource Brush.Success}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Settings.Settings.Model.ModelName, StringFormat=模型: {0}}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12" />
                    <TextBlock Text="{Binding SessionUsageLine}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SessionUsageLine}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SessionUsageLine}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{Binding LogsPath, StringFormat=Logs: {0}}"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding LogsPath}" />
            </Grid>
        </Border>

        <!-- Collapsed left affordance: Cursor-style floating icon (no chrome rail) -->
        <Button x:Name="NavigationSidebarCollapsedRail"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10,12,0,0"
                Panel.ZIndex="5"
                Style="{StaticResource RightSidebarToggleButtonStyle}"
                Command="{Binding ToggleNavigationSidebarCommand}"
                ToolTip="{Binding NavigationSidebarToggleToolTip}"
                Visibility="Collapsed">
            <controls:LeftSidebarToggleIcon Foreground="{DynamicResource Brush.SubtleText}"
                                            IsPanelOpen="{Binding IsNavigationSidebarVisible}" />
        </Button>

        <!-- Collapsed right affordance: same floating toggle as left (no chrome rail) -->
        <Button x:Name="ContextSidebarCollapsedRail"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,10,0"
                Panel.ZIndex="5"
                Style="{StaticResource RightSidebarToggleButtonStyle}"
                Command="{Binding ToggleContextSidebarCommand}"
                ToolTip="{Binding ContextSidebarToggleToolTip}"
                Visibility="Collapsed">
            <controls:RightSidebarToggleIcon Foreground="{DynamicResource Brush.SubtleText}"
                                             IsPanelOpen="{Binding IsContextSidebarVisible}" />
        </Button>

        <!-- Context panel -->

        <GridSplitter x:Name="NavigationSidebarSplitter"
                      Grid.Row="1"
                      Grid.RowSpan="2"
                      Grid.Column="0"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3">
            <i:Interaction.Behaviors>
                <behaviors:GridSplitterLayoutBehavior Kind="NavigationSidebar" />
            </i:Interaction.Behaviors>
        </GridSplitter>

        <GridSplitter x:Name="ContextSidebarSplitter"
                      Grid.Row="1"
                      Grid.RowSpan="2"
                      Grid.Column="1"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3">
            <i:Interaction.Behaviors>
                <behaviors:GridSplitterLayoutBehavior Kind="ContextSidebar" />
            </i:Interaction.Behaviors>
        </GridSplitter>
        </Grid>

        <Border Panel.ZIndex="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.45"
                                  BlurRadius="16"
                                  ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ToastNoticeStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCopyNoticeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding CopyNotice}"
                       Style="{StaticResource ToastNoticeTextStyle}" />
        </Border>

        <Border x:Name="ShutdownOverlay"
                Panel.ZIndex="200"
                Visibility="Collapsed"
                Background="{DynamicResource Brush.AppBackground}"
                Opacity="0.92">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="420">
                <TextBlock Text="{loc:Localize Key=Shell_ShuttingDown}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock Text="{Binding ShutdownStatusText}"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
