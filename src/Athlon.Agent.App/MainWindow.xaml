<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athlon Agent"
        Height="768"
        Width="1366"
        MinHeight="720"
        MinWidth="1100"
        Background="{StaticResource Brush.AppBackground}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Header (report/html AppHeader) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border Width="40" Height="40" CornerRadius="12" Background="{StaticResource Brush.IconBadge}" Margin="0,0,12,0">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Athlon Agent" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="AI 编程助手" FontSize="13" Foreground="{StaticResource Brush.SubtleText}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar (report/html Sidebar) -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <DockPanel LastChildFill="True">
                <!-- 须 Dock=Bottom 且排在 Fill 子元素之前；历史列表 ScrollViewer 放最后 -->
                <Border DockPanel.Dock="Bottom"
                        Background="{StaticResource Brush.PanelAlt}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,5"
                        Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="工作区"
                                   Foreground="{StaticResource Brush.SubtleText}"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ActiveWorkspaceName}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2"
                                Content="配置"
                                Command="{Binding ConfigureWorkspaceCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="6,2"
                                FontSize="10"
                                MinHeight="22"
                                MinWidth="40"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <TextBlock DockPanel.Dock="Top"
                           Text="对话"
                           FontSize="11"
                           FontWeight="Medium"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,0,0,16"
                           Opacity="0.8" />

                <StackPanel DockPanel.Dock="Top">
                    <Button Command="{Binding NewSessionCommand}" Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.NavActiveText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" Margin="0,0,12,0" />
                            <TextBlock Text="对话" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.NavActiveText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,12,0" />
                            <TextBlock Text="设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top"
                           Text="历史记录"
                           FontSize="11"
                           FontWeight="Medium"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,12,0,6" />
                <TextBlock DockPanel.Dock="Top"
                           Text="暂无历史记录"
                           FontSize="12"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionHistory}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionHistory}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding SessionHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="0"
                                        CornerRadius="12"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.Panel}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="12,10,4,10"
                                                HorizontalContentAlignment="Stretch"
                                                Cursor="Hand">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding UpdatedAtText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Brush.SubtleText}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="×"
                                                ToolTip="删除"
                                                Width="32"
                                                Height="32"
                                                Margin="4,0,6,0"
                                                Padding="0"
                                                FontSize="16"
                                                Foreground="{StaticResource Brush.SubtleText}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                VerticalAlignment="Center"
                                                Cursor="Hand" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main column: chat / settings + composer + footer -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Chat -->
            <Grid Grid.Row="0"
                  Background="{StaticResource Brush.ChatBackground}"
                  ClipToBounds="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Session toolbar -->
                <Border Grid.Row="0"
                        Background="{StaticResource Brush.Chrome}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="20,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasChatMessages}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,12,0" />
                        <Button Grid.Column="1"
                                Content="清空上下文"
                                Command="{Binding ClearContextCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="10,4"
                                FontSize="12"
                                MinHeight="28"
                                ToolTip="清空当前对话在模型中的可见历史；会话与工作区保留，磁盘 transcript 归档不删除。" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ClipToBounds="True">
                <!-- Empty state (EmptyConversation) -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="48" Height="48" CornerRadius="14" Background="{StaticResource Brush.IconBadge}" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="A" FontSize="22" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Start chatting with Athlon"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock Text="在下方输入问题，或使用技能与工具处理工作区文件。"
                               Foreground="{StaticResource Brush.SubtleText}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Messages (ChatPane bubbles) -->
                <ScrollViewer x:Name="ChatMessagesScrollViewer"
                              Padding="24,20,24,28"
                              VerticalScrollBarVisibility="Auto"
                              ClipToBounds="True"
                              CanContentScroll="False">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 对齐 report/html：用户 justify-end，助手 justify-start -->
                                <StackPanel Margin="0,0,0,16"
                                            Orientation="Horizontal"
                                            ClipToBounds="True">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="12"
                                            Background="{StaticResource Brush.IconBadge}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="A" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Orientation="Vertical"
                                                MaxWidth="680"
                                                ClipToBounds="True">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <!-- Tool message: collapsible thinking-style block -->
                                        <Border HorizontalAlignment="Stretch"
                                                MaxWidth="640"
                                                ClipToBounds="True"
                                                CornerRadius="16"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                Background="{StaticResource Brush.ToolThinkingBg}"
                                                Margin="0,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Button Command="{Binding ToggleToolExpandCommand}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="12,10"
                                                        HorizontalContentAlignment="Stretch"
                                                        Cursor="Hand">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ChevronGlyph}"
                                                                   Foreground="{StaticResource Brush.ToolThinkingText}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding CardTitle}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.ToolThinkingText}" />
                                                            <TextBlock Text="{Binding ToolHeader}"
                                                                       FontSize="11"
                                                                       Foreground="#C4B5FD"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding ToolSummary}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource Brush.SubtleText}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <Trigger Property="Text" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="执行中…"
                                                                       FontSize="11"
                                                                       Foreground="#86EFAC"
                                                                       Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsToolRunning}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CreatedAt}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource Brush.SubtleText}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                    </Grid>
                                                </Button>
                                                <Border BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                        BorderThickness="0,1,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <controls:MarkdownMessageView Margin="12,10"
                                                                                  Markdown="{Binding ToolDetail}"
                                                                                  AssistantTone="True"
                                                                                  MaxContentHeight="272"
                                                                                  HorizontalAlignment="Stretch">
                                                        <controls:MarkdownMessageView.Style>
                                                            <Style TargetType="controls:MarkdownMessageView">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </controls:MarkdownMessageView.Style>
                                                    </controls:MarkdownMessageView>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- User / assistant message bubble（对齐 report/html max-w-[85%]） -->
                                        <Border CornerRadius="24"
                                                Padding="20,16"
                                                BorderThickness="1"
                                                Margin="0,0,0,0"
                                                ClipToBounds="True">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Brush.AssistantBubble}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                    <Setter Property="MaxWidth" Value="640" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Brush.UserBubble}" />
                                                            <Setter Property="BorderBrush" Value="#1D4ED8" />
                                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                                            <Setter Property="MaxWidth" Value="520" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHiddenPlaceholder}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayRole}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.SubtleText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#DBEAFE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Reasoning block: collapsible thinking-style, default expanded -->
                                                <Border CornerRadius="16"
                                                        BorderThickness="1"
                                                        Background="{StaticResource Brush.ToolThinkingBg}"
                                                        BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                        Margin="0,0,0,12"
                                                        ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasReasoning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Button Command="{Binding ToggleReasoningExpandCommand}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="12,10"
                                                                HorizontalContentAlignment="Stretch"
                                                                Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding ReasoningChevronGlyph}"
                                                                           Foreground="{StaticResource Brush.ToolThinkingText}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0" />
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="思考过程"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource Brush.ToolThinkingText}" />
                                                                    <TextBlock Text="思考中…"
                                                                               FontSize="11"
                                                                               Foreground="#86EFAC"
                                                                               Margin="0,4,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsReasoningStreaming}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                        <Border BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                                BorderThickness="0,1,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsReasoningExpanded}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <controls:MarkdownMessageView Margin="12,10"
                                                                                          Markdown="{Binding ReasoningContent}"
                                                                                          AssistantTone="True"
                                                                                          MaxContentHeight="272"
                                                                                          HorizontalAlignment="Stretch" />
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <controls:MarkdownMessageView Markdown="{Binding Content}"
                                                                              AssistantTone="{Binding AssistantTone}"
                                                                              MaxContentHeight="0"
                                                                              HorizontalAlignment="Stretch" />
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.SubtleText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#BFDBFE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="12"
                                            Background="{StaticResource Brush.Accent}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="您" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Settings -->
            <ScrollViewer Grid.Row="0"
                            Padding="32,28"
                            VerticalScrollBarVisibility="Auto"
                            Background="{StaticResource Brush.ChatBackground}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel MaxWidth="760">
                    <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock Text="配置模型、MCP、技能、工作区与工具权限。"
                               Foreground="{StaticResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Model" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="Provider" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Endpoint" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Model Name" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <CheckBox IsChecked="{Binding Settings.Settings.Model.EnableStreaming, UpdateSourceTrigger=PropertyChanged}"
                                      Content="启用流式输出（SSE）"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="API Key" Foreground="{StaticResource Brush.SubtleText}" />
                            <PasswordBox x:Name="ApiKeyPasswordBox"
                                           PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged"
                                           Margin="0,6,0,6" />
                            <TextBlock Text="API Key 使用 Windows DPAPI 加密保存在用户目录。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Installed MCP Servers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="配置文件使用 Claude Desktop 格式，保存到 %USERPROFILE%/.athlon-agent/config/mcp.json。stdio 用 command/args；Streamable HTTP 用 type=http 与 url（可选 headers）。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding Settings.McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1B1B1E"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                                                    <Border Width="36" Height="36" CornerRadius="10" Background="#3F3F46">
                                                        <TextBlock Text="{Binding DisplayInitial}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                    </Border>
                                                    <Ellipse Width="10" Height="10"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"
                                                             Margin="0,0,-2,-2"
                                                             Stroke="#18181B"
                                                             StrokeThickness="2">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#71717A" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStatusHealthy}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource Brush.Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource Brush.Danger}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ShowStatusDot}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ToolSummary}"
                                                               Foreground="{StaticResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Style="{StaticResource McpIconButtonStyle}"
                                                        Content="✎"
                                                        ToolTip="编辑"
                                                        Command="{Binding DataContext.Settings.SelectMcpServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center" />
                                                <Button Grid.Column="3"
                                                        Style="{StaticResource McpIconButtonStyle}"
                                                        Content="🗑"
                                                        ToolTip="删除"
                                                        Command="{Binding DataContext.Settings.DeleteMcpServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center"
                                                        Margin="4,0,0,0" />
                                                <CheckBox Grid.Column="4"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Command="{Binding Settings.AddMcpServerCommand}" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Left" Content="+ New MCP Server" />

                            <Border Background="{StaticResource Brush.PanelAlt}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Selected MCP Server" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <TextBlock Text="Name" Foreground="{StaticResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding Settings.SelectedMcpServer.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                    <TextBlock Text="Command" Foreground="{StaticResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding Settings.SelectedMcpServer.Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                    <TextBlock Text="Args" Foreground="{StaticResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding Settings.EditableMcpArgs, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="启用" Foreground="{StaticResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <CheckBox Style="{StaticResource McpToggleSwitchStyle}"
                                                  IsChecked="{Binding Settings.SelectedMcpServer.Enabled, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Skills" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="技能从 ~/.athlon-agent/skills 自动加载。每个技能一个子目录，入口文件为 SKILL.md（YAML frontmatter 含 name、description）。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="示例目录结构："
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       FontSize="12"
                                       Margin="0,0,0,4" />
                            <TextBlock FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Text="skills/&#10;  my-skill/&#10;    SKILL.md&#10;    scripts/&#10;    references/" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Workspace" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="未填写路径时视为未配置工作区；也可在对话侧栏点击「配置」为当前会话指定目录。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,12" />
                            <TextBox Text="{Binding Settings.EditableWorkspace.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                            <TextBox Text="{Binding Settings.EditableWorkspace.RootPath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,24">
                        <TextBlock Text="{Binding SettingsStatus}" Foreground="{StaticResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Composer (report/html Composer hero/dock) -->
            <Border Grid.Row="1"
                    Panel.ZIndex="20"
                    Background="{StaticResource Brush.Chrome}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="20,16"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border MaxWidth="900"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource Brush.Composer}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="56" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBox x:Name="ComposerTextBox"
                                     Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="56"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="15"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewKeyDown="ComposerTextBox_OnPreviewKeyDown" />
                            <TextBlock Text="Message Athlon — @ 文件 / 技能，Enter 发送"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       Margin="4,14,0,0"
                                       IsHitTestVisible="False"
                                       FontSize="15">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComposerEmpty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="Enter 发送 · Shift+Enter 换行"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Grid HorizontalAlignment="Right">
                                <!-- 发送中显示停止，空闲时显示发送（对齐 report/html Composer isSending） -->
                                <Button Command="{Binding StopCommand}"
                                        ToolTip="暂停当前回复">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DangerCircleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="■" FontSize="12" />
                                </Button>
                                <Button Command="{Binding SendCommand}"
                                        ToolTip="发送">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryCircleButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="➤" FontSize="14" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Border>

        </Grid>

        <!-- 底部状态栏（主区域右侧） -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <TextBlock Text="{Binding Sidebar.LocalModelStatus, StringFormat=● {0}}"
                           Foreground="{StaticResource Brush.Success}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <TextBlock Text="{Binding Settings.Settings.Model.ModelName, StringFormat=模型: {0}}"
                           Foreground="{StaticResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <TextBlock Text="Logs: %USERPROFILE%/.athlon-agent/logs"
                           Foreground="{StaticResource Brush.SubtleText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </Grid>
        </Border>

        <!-- Context panel -->
        <Border Grid.Row="1"
                Grid.Column="2"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,0,0,0"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="技能" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <Border Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding Sidebar.Skills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,4"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Brush.Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="MCP 服务器" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <Border Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding Sidebar.McpServers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,4"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#86EFAC" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="工作区文件" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding ActiveWorkspaceName}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,8"
                               TextTrimming="CharacterEllipsis" />
                    <Border Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="8"
                            MaxHeight="360">
                        <TreeView ItemsSource="{Binding Sidebar.WorkspaceTree}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontSize="13">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True" />
                                    <Setter Property="Padding" Value="2,4" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
        </Grid>

        <!-- 复制提示：对齐 report/html bg-slate-900 + text-white -->
        <Border Panel.ZIndex="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0"
                Padding="16,12"
                CornerRadius="16"
                Background="#0F172A"
                BorderBrush="#334155"
                BorderThickness="1"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.45"
                                  BlurRadius="16"
                                  ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCopyNoticeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding CopyNotice}"
                       Foreground="#FFFFFF"
                       FontSize="13" />
        </Border>
    </Grid>
</Window>
