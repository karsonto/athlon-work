<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athlon Agent"
        Height="768"
        Width="1366"
        MinHeight="720"
        MinWidth="1100"
        Background="{StaticResource Brush.AppBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Header (report/html AppHeader) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border Width="40" Height="40" CornerRadius="12" Background="{StaticResource Brush.IconBadge}" Margin="0,0,12,0">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Athlon Agent" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="AI 编程助手" FontSize="13" Foreground="{StaticResource Brush.SubtleText}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="0,8,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="−"
                            ToolTip="最小化"
                            Click="MinimizeButton_OnClick"
                            Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button x:Name="MaximizeRestoreButton"
                            Content="□"
                            ToolTip="最大化"
                            Click="MaximizeRestoreButton_OnClick"
                            Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button Content="×"
                            ToolTip="关闭"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource WindowCloseCaptionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar (report/html Sidebar) -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <DockPanel LastChildFill="True">
                <!-- 须 Dock=Bottom 且排在 Fill 子元素之前；历史列表 ScrollViewer 放最后 -->
                <Border DockPanel.Dock="Bottom"
                        Background="{StaticResource Brush.PanelAlt}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,5"
                        Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="工作区"
                                   Foreground="{StaticResource Brush.SubtleText}"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ActiveWorkspaceName}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2"
                                Content="配置"
                                Command="{Binding ConfigureWorkspaceCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="6,2"
                                FontSize="10"
                                MinHeight="22"
                                MinWidth="40"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <TextBlock DockPanel.Dock="Top"
                           Text="对话"
                           FontSize="11"
                           FontWeight="Medium"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,0,0,16"
                           Opacity="0.8" />

                <StackPanel DockPanel.Dock="Top">
                    <Button Command="{Binding NewSessionCommand}" Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.NavActiveText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" Margin="0,0,12,0" />
                            <TextBlock Text="对话" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.NavActiveText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,12,0" />
                            <TextBlock Text="设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top"
                           Text="历史记录"
                           FontSize="11"
                           FontWeight="Medium"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,12,0,6" />
                <TextBlock DockPanel.Dock="Top"
                           Text="暂无历史记录"
                           FontSize="12"
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="8,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionHistory}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSessionHistory}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding SessionHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="0"
                                        CornerRadius="12"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.Panel}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Brush.NavActiveBg}" />
                                                    <Setter Property="BorderBrush" Value="#3B82F6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SessionHistoryButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding UpdatedAtText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Brush.SubtleText}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="×"
                                                ToolTip="删除"
                                                Width="32"
                                                Height="32"
                                                Margin="4,0,6,0"
                                                Padding="0"
                                                FontSize="16"
                                                Foreground="{StaticResource Brush.SubtleText}"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SessionDeleteButtonStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main column: chat / settings + composer + footer -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Chat -->
            <Grid Grid.Row="0"
                  Background="{StaticResource Brush.ChatBackground}"
                  ClipToBounds="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Session toolbar -->
                <Border Grid.Row="0"
                        Background="{StaticResource Brush.Chrome}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="20,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasChatMessages}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,12,0" />
                        <Button Grid.Column="1"
                                Content="清空上下文"
                                Command="{Binding ClearContextCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="10,4"
                                FontSize="12"
                                MinHeight="28"
                                ToolTip="清空当前对话在模型中的可见历史；会话与工作区保留，磁盘 transcript 归档不删除。" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ClipToBounds="True">
                <!-- Empty state (EmptyConversation) -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="48" Height="48" CornerRadius="14" Background="{StaticResource Brush.IconBadge}" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="A" FontSize="22" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Start chatting with Athlon"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock Text="在下方输入问题，或使用技能与工具处理工作区文件。"
                               Foreground="{StaticResource Brush.SubtleText}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Messages (ChatPane bubbles) -->
                <ScrollViewer x:Name="ChatMessagesScrollViewer"
                              Padding="24,20,24,28"
                              VerticalScrollBarVisibility="Auto"
                              ClipToBounds="True"
                              CanContentScroll="False">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 对齐 report/html：用户 justify-end，助手 justify-start -->
                                <StackPanel Margin="0,0,0,16"
                                            Orientation="Horizontal"
                                            ClipToBounds="True">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="12"
                                            Background="{StaticResource Brush.IconBadge}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="A" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Orientation="Vertical"
                                                MaxWidth="680"
                                                ClipToBounds="True">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <!-- Tool message: collapsible thinking-style block -->
                                        <Border HorizontalAlignment="Stretch"
                                                MaxWidth="640"
                                                ClipToBounds="True"
                                                CornerRadius="16"
                                                BorderThickness="1"
                                                Margin="0,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolThinkingBorder}" />
                                                    <Setter Property="Background" Value="{StaticResource Brush.ToolThinkingBg}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Preparing}">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolThinkingBorder}" />
                                                            <Setter Property="Background" Value="{StaticResource Brush.ToolThinkingBg}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Running}">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolThinkingBorder}" />
                                                            <Setter Property="Background" Value="{StaticResource Brush.ToolThinkingBg}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Succeeded}">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolSuccessBorder}" />
                                                            <Setter Property="Background" Value="{StaticResource Brush.ToolSuccessBg}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Failed}">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolFailureBorder}" />
                                                            <Setter Property="Background" Value="{StaticResource Brush.ToolFailureBg}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Cancelled}">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.ToolFailureBorder}" />
                                                            <Setter Property="Background" Value="{StaticResource Brush.ToolFailureBg}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Button Command="{Binding ToggleToolExpandCommand}"
                                                        Style="{StaticResource CollapsibleHeaderButtonStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ChevronGlyph}"
                                                                   Foreground="{StaticResource Brush.ToolThinkingText}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding CardTitle}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brush.ToolThinkingText}" />
                                                            <TextBlock Text="{Binding ToolHeader}"
                                                                       FontSize="11"
                                                                       Foreground="#C4B5FD"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding ToolArgumentsText}"
                                                                       FontSize="11"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{StaticResource Brush.Text}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,6,0,0"
                                                                       MaxHeight="160">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasToolArguments}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding ToolSummary}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource Brush.SubtleText}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <Trigger Property="Text" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding ToolStatusLabel}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Setter Property="Foreground" Value="#C4B5FD" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ShowToolStatusLabel}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Preparing}">
                                                                                <Setter Property="Foreground" Value="#86EFAC" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Running}">
                                                                                <Setter Property="Foreground" Value="#86EFAC" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Succeeded}">
                                                                                <Setter Property="Foreground" Value="{StaticResource Brush.ToolSuccessText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Failed}">
                                                                                <Setter Property="Foreground" Value="{StaticResource Brush.ToolFailureText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Cancelled}">
                                                                                <Setter Property="Foreground" Value="{StaticResource Brush.ToolFailureText}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CreatedAt}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource Brush.SubtleText}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                    </Grid>
                                                </Button>
                                                <Border BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                        BorderThickness="0,1,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <controls:MarkdownMessageView Margin="12,10"
                                                                                  Markdown="{Binding ToolDetail}"
                                                                                  AssistantTone="True"
                                                                                  MaxContentHeight="272"
                                                                                  HorizontalAlignment="Stretch">
                                                        <controls:MarkdownMessageView.Style>
                                                            <Style TargetType="controls:MarkdownMessageView">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </controls:MarkdownMessageView.Style>
                                                    </controls:MarkdownMessageView>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- User / assistant message bubble（对齐 report/html max-w-[85%]） -->
                                        <Border CornerRadius="24"
                                                Padding="20,16"
                                                BorderThickness="1"
                                                Margin="0,0,0,0"
                                                ClipToBounds="True">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Brush.AssistantBubble}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                    <Setter Property="MaxWidth" Value="640" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Brush.UserBubble}" />
                                                            <Setter Property="BorderBrush" Value="#2F5C8E" />
                                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                                            <Setter Property="MaxWidth" Value="520" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHiddenPlaceholder}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayRole}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.SubtleText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#DBEAFE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Reasoning block: collapsible thinking-style, default expanded -->
                                                <Border CornerRadius="16"
                                                        BorderThickness="1"
                                                        Background="{StaticResource Brush.ToolThinkingBg}"
                                                        BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                        Margin="0,0,0,12"
                                                        ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasReasoning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Button Command="{Binding ToggleReasoningExpandCommand}"
                                                                Style="{StaticResource CollapsibleHeaderButtonStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding ReasoningChevronGlyph}"
                                                                           Foreground="{StaticResource Brush.ToolThinkingText}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0" />
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="思考过程"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource Brush.ToolThinkingText}" />
                                                                    <TextBlock Text="思考中…"
                                                                               FontSize="11"
                                                                               Foreground="#86EFAC"
                                                                               Margin="0,4,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsReasoningStreaming}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                        <Border BorderBrush="{StaticResource Brush.ToolThinkingBorder}"
                                                                BorderThickness="0,1,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsReasoningExpanded}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <controls:MarkdownMessageView Margin="12,10"
                                                                                          Markdown="{Binding ReasoningContent}"
                                                                                          AssistantTone="True"
                                                                                          MaxContentHeight="272"
                                                                                          HorizontalAlignment="Stretch" />
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{Binding UserAttachmentSummary}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Brush.SubtleText}"
                                                           Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UserAttachmentSummary}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <controls:MarkdownMessageView Markdown="{Binding Content}"
                                                                              AssistantTone="{Binding AssistantTone}"
                                                                              MaxContentHeight="0"
                                                                              HorizontalAlignment="Stretch" />
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.SubtleText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#BFDBFE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Width="40"
                                            Height="40"
                                            CornerRadius="12"
                                            Background="{StaticResource Brush.Accent}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="您" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Settings -->
            <ScrollViewer Grid.Row="0"
                            Padding="32,28"
                            VerticalScrollBarVisibility="Auto"
                            Background="{StaticResource Brush.ChatBackground}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel MaxWidth="760">
                    <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock Text="配置模型、MCP、技能、工作区与工具权限。"
                               Foreground="{StaticResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Model" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="Provider" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Endpoint" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Model Name" Foreground="{StaticResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <CheckBox IsChecked="{Binding Settings.Settings.Model.EnableStreaming, UpdateSourceTrigger=PropertyChanged}"
                                      Content="启用流式输出（SSE）"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="API Key" Foreground="{StaticResource Brush.SubtleText}" />
                            <PasswordBox x:Name="ApiKeyPasswordBox"
                                           PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged"
                                           Margin="0,6,0,6" />
                            <TextBlock Text="API Key 使用 Windows DPAPI 加密保存在用户目录。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Installed MCP Servers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="MCP 服务从 %USERPROFILE%/.athlon-agent/config/mcp.json 读取；此页面仅控制每个服务是否启用。新增、删除和命令参数请直接修改 JSON 配置。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding Settings.McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1B1B1E"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                                                    <Border Width="36" Height="36" CornerRadius="10" Background="#3F3F46">
                                                        <TextBlock Text="{Binding DisplayInitial}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                    </Border>
                                                    <Ellipse Width="10" Height="10"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"
                                                             Margin="0,0,-2,-2"
                                                             Stroke="#18181B"
                                                             StrokeThickness="2">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#71717A" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStatusHealthy}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource Brush.Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource Brush.Danger}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ShowStatusDot}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ToolSummary}"
                                                               Foreground="{StaticResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>

                                                <CheckBox Grid.Column="2"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Skills" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="技能从 ~/.athlon-agent/skills 自动加载。每个技能一个子目录，入口文件为 SKILL.md（YAML frontmatter 含 name、description）。"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="示例目录结构："
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       FontSize="12"
                                       Margin="0,0,0,4" />
                            <TextBlock FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Text="skills/&#10;  my-skill/&#10;    SKILL.md&#10;    scripts/&#10;    references/" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,24">
                        <TextBlock Text="{Binding SettingsStatus}" Foreground="{StaticResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Composer (report/html Composer hero/dock) -->
            <Border Grid.Row="1"
                    Panel.ZIndex="20"
                    Background="{StaticResource Brush.Chrome}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="20,16"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border MaxWidth="900"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource Brush.Composer}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="56" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="0,0,0,6">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPendingImages}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding PendingImageAttachments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Brush.PanelAlt}"
                                                    BorderBrush="{StaticResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Margin="0,0,8,0"
                                                    Padding="10,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="220"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Content="×"
                                                            Command="{Binding DataContext.RemovePendingImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{StaticResource Brush.SubtleText}"
                                                            FontSize="12"
                                                            Padding="4,0,0,0"
                                                            Margin="6,0,0,0"
                                                            Cursor="Hand"
                                                            VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBox x:Name="ComposerTextBox"
                                     Grid.Row="1"
                                     Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="56"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="15"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="ComposerTextBox_OnTextChanged"
                                     PreviewKeyDown="ComposerTextBox_OnPreviewKeyDown" />
                            <TextBlock Text="Message Athlon — @ 文件 / 技能，Enter 发送"
                                       Grid.Row="1"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       Margin="4,14,0,0"
                                       IsHitTestVisible="False"
                                       FontSize="15">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComposerEmpty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Popup IsOpen="{Binding IsAtCompletionOpen}"
                               PlacementTarget="{Binding ElementName=ComposerTextBox}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{StaticResource Brush.Panel}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6"
                                    MinWidth="340"
                                    MaxWidth="560"
                                    MaxHeight="240">
                                <ListBox x:Name="AtCompletionListBox"
                                         ItemsSource="{Binding AtCompletionItems}"
                                         SelectedIndex="{Binding SelectedAtCompletionIndex}"
                                         MouseDoubleClick="AtCompletionListBox_OnMouseDoubleClick"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{StaticResource Brush.PanelAlt}"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{StaticResource Brush.SubtleText}" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SecondaryText}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource Brush.SubtleText}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Button Command="{Binding SelectImagesCommand}"
                                    Style="{StaticResource ComposerIconButtonStyle}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Width="24"
                                    Height="24"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    ToolTip="上传图片"
                                    Foreground="{StaticResource Brush.SubtleText}">
                                <TextBlock Text="+"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,-2,0,0" />
                            </Button>
                            <TextBlock Text="Enter 发送 · Shift+Enter 换行"
                                       Foreground="{StaticResource Brush.SubtleText}"
                                       FontSize="12"
                                       Margin="34,0,0,0"
                                       VerticalAlignment="Center" />
                            <Grid HorizontalAlignment="Right">
                                <!-- 发送中显示停止，空闲时显示发送（对齐 report/html Composer isSending） -->
                                <Button Command="{Binding StopCommand}"
                                        ToolTip="暂停当前回复">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DangerCircleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="■" FontSize="12" />
                                </Button>
                                <Button Command="{Binding SendCommand}"
                                        ToolTip="发送">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryCircleButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="➤" FontSize="14" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Border>

        </Grid>

        <!-- 底部状态栏（主区域右侧） -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <TextBlock Text="{Binding Sidebar.LocalModelStatus, StringFormat=● {0}}"
                           Foreground="{StaticResource Brush.Success}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <TextBlock Text="{Binding Settings.Settings.Model.ModelName, StringFormat=模型: {0}}"
                           Foreground="{StaticResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <TextBlock Text="Logs: %USERPROFILE%/.athlon-agent/logs"
                           Foreground="{StaticResource Brush.SubtleText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </Grid>
        </Border>

        <!-- Context panel -->
        <Border Grid.Row="1"
                Grid.Column="2"
                Background="{StaticResource Brush.Chrome}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,0,0,0"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="技能" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <Border Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding Sidebar.Skills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,4"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Brush.Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="MCP 服务器" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <Border Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding Sidebar.McpServers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <Button Command="{Binding ToggleExpandedCommand}"
                                                Style="{StaticResource McpSidebarItemButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"
                                                         Style="{StaticResource McpStatusIndicatorStyle}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{StaticResource McpStatusNameStyle}" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="{StaticResource Brush.SubtleText}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Chevron}"
                                                           Foreground="{StaticResource Brush.SubtleText}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasTools}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Button>
                                        <ItemsControl ItemsSource="{Binding ToolNames}" Margin="22,2,0,4">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource Brush.SubtleText}"
                                                               FontSize="11"
                                                               Margin="0,1"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="工作区文件" Foreground="{StaticResource Brush.SubtleText}" FontSize="12" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding ActiveWorkspaceName}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,8"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="8">
                        <TreeView ItemsSource="{Binding Sidebar.WorkspaceTree}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontSize="13"
                                  Foreground="{StaticResource Brush.Text}"
                                  MouseDoubleClick="WorkspaceTree_OnMouseDoubleClick">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource WorkspaceTreeViewItemStyle}" />
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        </Grid>

        <Border Panel.ZIndex="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.45"
                                  BlurRadius="16"
                                  ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ToastNoticeStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCopyNoticeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding CopyNotice}"
                       Style="{StaticResource ToastNoticeTextStyle}" />
        </Border>
    </Grid>
</Window>
