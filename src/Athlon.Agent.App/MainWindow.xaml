<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:app="clr-namespace:Athlon.Agent.App"
        xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athlon Agent"
        Icon="/Assets/app-icon.ico"
        Height="768"
        Width="1366"
        MinHeight="720"
        MinWidth="1100"
        Background="{DynamicResource Brush.AppBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control+Alt" Command="{Binding ToggleContextSidebarCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveActiveEditorCommand}" />
    </Window.InputBindings>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{x:Static app:AppLayoutMetrics.WindowChromeRowHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationSidebarColumn"
                              Width="280"
                              MinWidth="180"
                              MaxWidth="480" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ContextSidebarColumn"
                              Width="320"
                              MinWidth="220"
                              MaxWidth="560" />
        </Grid.ColumnDefinitions>

        <!-- Window chrome (minimize / maximize / close only) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource Brush.Chrome}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,0">
                    <Image Source="/Assets/app-icon-48.png"
                           Width="16"
                           Height="16"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <Menu Style="{StaticResource TitleBarMenuStyle}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True"
                          VerticalAlignment="Stretch">
                        <MenuItem Header="Help"
                                  Style="{StaticResource TitleBarTopMenuItemStyle}">
                            <MenuItem Header="About"
                                      Click="HelpAboutMenuItem_OnClick" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="−"
                            ToolTip="最小化"
                            Click="MinimizeButton_OnClick"
                            Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button x:Name="MaximizeRestoreButton"
                            Content="□"
                            ToolTip="最大化"
                            Click="MaximizeRestoreButton_OnClick"
                            Style="{StaticResource WindowCaptionButtonStyle}" />
                    <Button Content="×"
                            ToolTip="关闭"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource WindowCloseCaptionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left sidebar — session list -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource Brush.AppBackground}"
                BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{x:Static app:AppLayoutMetrics.PanelHeaderRowHeight}" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}" Padding="20,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/app-icon-48.png"
                                   Width="24"
                                   Height="24"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="Athlon" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Command="{Binding NewSessionCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                ToolTip="新建会话"
                                Style="{StaticResource NewSessionButtonStyle}">
                            <TextBlock Text="+" FontSize="16" FontWeight="SemiBold" Margin="0,-1,0,0" />
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="暂无 Agent 记录"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.SubtleText}"
                                   Margin="12,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding AgentRecordGroups}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AgentRecordGroupViewModel}">
                                    <StackPanel>
                                        <Button Command="{Binding ToggleExpandedCommand}"
                                                Style="{StaticResource AgentRecordGroupHeaderStyle}">
                                            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding ExpandGlyph}"
                                                           FontSize="10"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.DisabledText}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Items.Count}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Brush.SubtleText}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:SessionHistoryItemViewModel}">
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource SessionItemBorderStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="BorderThickness" Value="3,1,1,1" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     Margin="0,0,10,0"
                                                                     VerticalAlignment="Center"
                                                                     Fill="{DynamicResource Brush.SubtleText}">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                            <Button Grid.Column="1"
                                                                    Command="{Binding DataContext.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource SessionHistoryButtonStyle}"
                                                                    Padding="0,0,8,0">
                                                                <StackPanel HorizontalAlignment="Stretch">
                                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SessionNameTextStyle}" />
                                                                    <TextBlock Text="{Binding MetaText}" Style="{StaticResource SessionMetaTextStyle}" />
                                                                </StackPanel>
                                                            </Button>
                                                            <StackPanel Grid.Column="2"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <Button Command="{Binding StopSessionCommand}"
                                                                        Content="■"
                                                                        ToolTip="停止生成"
                                                                        Foreground="{DynamicResource Brush.Warning}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SessionActionButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="×"
                                                                        ToolTip="删除"
                                                                        Style="{StaticResource SessionActionButtonStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="12,0,12,12">
                    <Border Background="{DynamicResource Brush.PanelAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,8"
                            Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasQueuedTurns}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="排队中"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       Margin="0,0,0,6" />
                            <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding QueuedTurns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:QueuedTurnViewModel}">
                                            <Border Background="{DynamicResource Brush.Panel}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="8,8"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding PreviewText}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Brush.Text}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="40">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding PreviewText}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <ItemsControl ItemsSource="{Binding ImageItems}" Margin="0,6,0,0">
                                                            <ItemsControl.Style>
                                                                <Style TargetType="ItemsControl">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasImages}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ItemsControl.Style>
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:QueuedTurnImageViewModel}">
                                                                    <Border Width="44"
                                                                            Height="44"
                                                                            CornerRadius="8"
                                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                                            BorderThickness="1"
                                                                            Background="{DynamicResource Brush.PanelAlt}"
                                                                            Margin="0,0,8,0"
                                                                            ToolTip="{Binding FileName}">
                                                                        <Grid>
                                                                            <Image Source="{Binding Thumbnail}"
                                                                                   Stretch="UniformToFill"
                                                                                   Margin="2" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="×"
                                                            Command="{Binding DataContext.RemoveQueuedTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="从队列移除"
                                                            Style="{StaticResource SessionDeleteButtonStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Schedule navigation button -->
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Schedule"
                            Style="{StaticResource NavBottomButtonStyle}"
                            ToolTip="定时任务">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏰" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="定时任务" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main column: chat / settings + composer + footer -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- Chat -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource Brush.ChatBackground}"
                  ClipToBounds="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="EditorPaneColumn" Width="0" MinWidth="0" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="EditorPaneHost"
                        Grid.Column="0"
                        Background="{DynamicResource Brush.AppBackground}"
                        BorderThickness="0"
                        Visibility="Collapsed">
                    <Grid>
                        <controls:FileEditorView DataContext="{Binding FileEditor}" />
                    </Grid>
                </Border>

                <GridSplitter x:Name="EditorChatSplitter"
                              Grid.Column="0"
                              Style="{StaticResource LayoutColumnSplitterStyle}"
                              ResizeDirection="Columns"
                              ResizeBehavior="CurrentAndNext"
                              Panel.ZIndex="2"
                              Visibility="Collapsed"
                              DragCompleted="EditorChatSplitter_OnDragCompleted" />

                <Grid Grid.Column="1" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition x:Name="ComposerRow"
                                   Height="168"
                                   MinHeight="120"
                                   MaxHeight="420" />
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0"
                        Height="{x:Static app:AppLayoutMetrics.PanelHeaderHeight}"
                        Background="{DynamicResource Brush.Chrome}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="24,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,12,0" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding ToggleThemeCommand}"
                                    ToolTip="{Binding ThemeToggleToolTip}"
                                    Style="{StaticResource IconButtonStyle}">
                                <TextBlock Text="{Binding ThemeToggleGlyph}" FontSize="14" />
                            </Button>
                            <Button Command="{Binding NavigateCommand}"
                                    CommandParameter="Settings"
                                    ToolTip="设置"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="4,0,0,0">
                                <TextBlock Text="⚙" FontSize="14" />
                            </Button>
                            <Button Command="{Binding ToggleContextSidebarCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="4,0,0,0"
                                    ToolTip="{Binding ContextSidebarToggleToolTip}">
                                <controls:RightSidebarToggleIcon IsPanelOpen="{Binding IsContextSidebarVisible}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ClipToBounds="True">
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720" Margin="24">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="💬"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Opacity="0.5"
                               Margin="0,0,0,24" />
                    <TextBlock Text="开始新的对话"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock Text="Athlon Agent 可以帮您分析代码、生成原型、优化设计，或执行任何开发任务。"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Loading indicator -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingSession}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="⏳"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Opacity="0.7"
                               Margin="0,0,0,12" />
                    <TextBlock Text="正在加载对话…"
                               FontSize="16"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Messages (ChatPane bubbles) -->
                <ListBox x:Name="ChatMessagesList"
                             ItemsSource="{Binding Messages}"
                             Padding="24,24"
                             ClipToBounds="True"
                             PreviewMouseLeftButtonDown="ChatMessagesScrollViewer_OnPreviewMouseLeftButtonDown"
                             PreviewMouseLeftButtonUp="ChatMessagesScrollViewer_OnPreviewMouseLeftButtonUp">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- 对齐 report/html：用户 justify-end，助手 justify-start -->
                                <StackPanel Margin="0,0,0,16"
                                            Orientation="Horizontal"
                                            ClipToBounds="True">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Setter Property="Margin" Value="0,0,0,16" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                    <Setter Property="Margin" Value="0,0,0,4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Image RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image" BasedOn="{StaticResource MessageAvatarAssistantImageStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <StackPanel Orientation="Vertical"
                                                MaxWidth="640"
                                                ClipToBounds="True">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <!-- Tool message card -->
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ToolCardBorderStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Border Style="{StaticResource ToolCardHeaderBorderStyle}">
                                                    <Button Command="{Binding ToggleToolExpandCommand}"
                                                            Style="{StaticResource CollapsibleHeaderButtonStyle}"
                                                            Padding="0"
                                                            Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ChevronGlyph}"
                                                                   Foreground="{DynamicResource Brush.ToolThinkingText}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding CardTitle}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.ToolThinkingText}" />
                                                            <TextBlock Text="{Binding ToolHeader}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding ToolArgumentsText}"
                                                                       FontSize="10"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{DynamicResource Brush.ToolThinkingText}"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="56"
                                                                       Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsToolArgumentsStreaming}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding ToolStatusLabel}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.AtCompletionSkillBadgeText}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ShowToolStatusLabel}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Preparing}">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ToolSuccessText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Running}">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ToolSuccessText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Succeeded}">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ToolSuccessText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Failed}">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ToolFailureText}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToolCallStatus}" Value="{x:Static vm:ToolCallDisplayStatus.Cancelled}">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ToolFailureText}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CreatedAt}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource Brush.SubtleText}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                    </Grid>
                                                </Button>
                                                </Border>
                                                <Border BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="0,1,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Margin="12,10">
                                                        <ScrollViewer MaxHeight="160"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      Margin="0,0,0,8">
                                                            <ScrollViewer.Style>
                                                                <Style TargetType="ScrollViewer">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ShowToolArgumentsPanel}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ScrollViewer.Style>
                                                            <TextBlock Text="{Binding ToolArgumentsText}"
                                                                       FontSize="11"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{DynamicResource Brush.ToolThinkingText}"
                                                                       TextWrapping="Wrap" />
                                                        </ScrollViewer>
                                                        <TextBlock Text="{Binding ToolSummary}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.SubtleText}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,8">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Text" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <controls:MarkdownMessageView Markdown="{Binding ToolDetailDisplay}"
                                                                                      AssistantTone="True"
                                                                                      MaxContentHeight="0"
                                                                                      HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- User / assistant message bubble -->
                                        <StackPanel>
                                        <Border ClipToBounds="True">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource MessageBubbleAssistantStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Brush.UserBubble}" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHiddenPlaceholder}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Reasoning block: collapsible thinking-style, default expanded -->
                                                <Border CornerRadius="16"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource Brush.ToolThinkingBg}"
                                                        BorderBrush="{DynamicResource Brush.ToolThinkingBorder}"
                                                        Margin="0,0,0,12"
                                                        ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasReasoning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Button Command="{Binding ToggleReasoningExpandCommand}"
                                                                Style="{StaticResource CollapsibleHeaderButtonStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding ReasoningChevronGlyph}"
                                                                           Foreground="{DynamicResource Brush.ToolThinkingText}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0" />
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="思考过程"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource Brush.ToolThinkingText}" />
                                                                    <TextBlock Text="思考中…"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource Brush.Success}"
                                                                               Margin="0,4,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsReasoningStreaming}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                        <Border BorderBrush="{DynamicResource Brush.ToolThinkingBorder}"
                                                                BorderThickness="0,1,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsReasoningExpanded}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <TextBlock Margin="12,10"
                                                                           Text="{Binding ReasoningContent}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource Brush.ToolThinkingText}"
                                                                           HorizontalAlignment="Stretch">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsReasoningStreaming}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <controls:MarkdownMessageView Margin="12,10"
                                                                                              Markdown="{Binding ReasoningContent}"
                                                                                              AssistantTone="True"
                                                                                              MaxContentHeight="0"
                                                                                              HorizontalAlignment="Stretch">
                                                                    <controls:MarkdownMessageView.Style>
                                                                        <Style TargetType="controls:MarkdownMessageView">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsReasoningStreaming}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </controls:MarkdownMessageView.Style>
                                                                </controls:MarkdownMessageView>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{Binding UserAttachmentSummary}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.SubtleText}"
                                                           Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UserAttachmentSummary}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="14"
                                                           HorizontalAlignment="Stretch"
                                                           xml:space="preserve">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsMarkdownDeferred}" Value="True" />
                                                                        <Condition Binding="{Binding IsMarkdownRenderingEnabled}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                                           Text="正在准备格式渲染…（点击立即渲染）"
                                                           Cursor="Hand">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding EnableMarkdownRenderingCommand}" />
                                                    </TextBlock.InputBindings>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsMarkdownDeferred}" Value="True" />
                                                                        <Condition Binding="{Binding IsMarkdownRenderingEnabled}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <controls:MarkdownMessageView Markdown="{Binding Content}"
                                                                              AssistantTone="{Binding AssistantTone}"
                                                                              MaxContentHeight="0"
                                                                              HorizontalAlignment="Stretch">
                                                    <controls:MarkdownMessageView.Style>
                                                        <Style TargetType="controls:MarkdownMessageView">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsMarkdownDeferred}" Value="True" />
                                                                        <Condition Binding="{Binding IsMarkdownRenderingEnabled}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </controls:MarkdownMessageView.Style>
                                                </controls:MarkdownMessageView>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding CreatedAt}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MessageMetaTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleCard}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHiddenPlaceholder}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource MessageAvatarUserStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="U" Foreground="{DynamicResource Brush.TextSecondary}" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource ChatMessageListBoxStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                    </ListBox>
                </Grid>

                <GridSplitter x:Name="ComposerSplitter"
                              Grid.Row="2"
                              Style="{StaticResource LayoutRowSplitterStyle}"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Panel.ZIndex="2"
                              DragCompleted="ComposerSplitter_OnDragCompleted" />

            <!-- Composer -->
            <Border Grid.Row="3"
                    Panel.ZIndex="20"
                    Style="{StaticResource ComposerOuterBorderStyle}"
                    ClipToBounds="True">
                <Border x:Name="ComposerInputWrapper"
                        Style="{StaticResource ComposerInputWrapperStyle}"
                        MaxWidth="900"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="56" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0,0,0,6">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingImages}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding PendingImageAttachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.PanelAlt}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,8,0"
                                                Padding="6,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="40"
                                                        Height="40"
                                                        CornerRadius="8"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource Brush.Panel}"
                                                        Margin="0,0,8,0">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           Margin="2" />
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding FileName}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="2"
                                                        Content="×"
                                                        Command="{Binding DataContext.RemovePendingImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SessionDeleteButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="1">
                            <TextBox x:Name="ComposerTextBox"
                                     Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ComposerTextBoxStyle}"
                                     TextChanged="ComposerTextBox_OnTextChanged"
                                     PreviewKeyDown="ComposerTextBox_OnPreviewKeyDown" />
                            <TextBlock Text="输入消息... (Shift+Enter 换行，Enter 发送)"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       Margin="8,8,0,0"
                                       IsHitTestVisible="False"
                                       FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComposerEmpty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Popup Grid.Row="1"
                               IsOpen="{Binding IsAtCompletionOpen, Mode=OneWay}"
                               PlacementTarget="{Binding ElementName=ComposerTextBox}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource Brush.Panel}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6"
                                    MinWidth="340"
                                    MaxWidth="560"
                                    MaxHeight="240">
                                <ListBox x:Name="AtCompletionListBox"
                                         ItemsSource="{Binding AtCompletionItems}"
                                         SelectedIndex="{Binding SelectedAtCompletionIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Focusable="False"
                                         KeyboardNavigation.DirectionalNavigation="Contained"
                                         MouseDoubleClick="AtCompletionListBox_OnMouseDoubleClick"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ItemContainerStyle="{StaticResource CompletionListBoxItemStyle}">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAtCompletionOpen}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Brush.AtCompletionFileBadgeBg}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.AtCompletionFileBadgeBorder}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="技能">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.AtCompletionSkillBadgeBg}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.AtCompletionSkillBadgeBorder}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Type}" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.AtCompletionFileBadgeText}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="技能">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.AtCompletionSkillBadgeText}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding PrimaryText}" FontSize="13" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SecondaryText}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Button Command="{Binding SelectImagesCommand}"
                                            Style="{StaticResource ComposerToolButtonStyle}"
                                            ToolTip="上传图片（支持 Ctrl+V 粘贴）">
                                        <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" Margin="0,-2,0,0" />
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding StopCommand}"
                                            ToolTip="暂停当前回复"
                                            Margin="0,0,8,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerCircleButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="■" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SendCommand}"
                                            ToolTip="发送（生成中将加入排队）"
                                            Style="{StaticResource ComposerSendButtonStyle}">
                                        <TextBlock Text="➤" FontSize="12" />
                                    </Button>
                                </StackPanel>
                        </Grid>
                        <TextBlock Grid.Row="3"
                                   Text="按 Enter 发送消息，Shift+Enter 换行"
                                   Foreground="{DynamicResource Brush.DisabledText}"
                                   FontSize="11"
                                   Margin="4,8,0,0" />
                    </Grid>
                </Border>
            </Border>
                </Grid>
            </Grid>

            <!-- Settings -->
            <ScrollViewer Grid.Row="0"
                            Padding="40,32"
                            VerticalScrollBarVisibility="Auto"
                            Background="{DynamicResource Brush.ChatBackground}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel MaxWidth="760">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Chat"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="返回对话"
                                Content="←" />
                        <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="配置模型、MCP、技能、工作区、上下文压缩与工具权限。"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Model" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="Provider" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Endpoint" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Model Name" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Settings.Model.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="Max Tokens" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.ModelMaxTokensText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,6" />
                            <TextBlock Text="单次回复最大输出 token（留空则使用 API 默认值）。仅影响对话补全，不影响上下文摘要。"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />
                            <CheckBox IsChecked="{Binding Settings.Settings.Model.EnableStreaming, UpdateSourceTrigger=PropertyChanged}"
                                      Content="启用流式输出（SSE）"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="API Key" Foreground="{DynamicResource Brush.SubtleText}" />
                            <PasswordBox x:Name="ApiKeyPasswordBox"
                                           PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged"
                                           Margin="0,6,0,6" />
                            <TextBlock Text="API Key 使用 Windows DPAPI 加密保存在用户目录。"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="长期记忆"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      IsChecked="{Binding Settings.Settings.Memory.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="启用长期记忆"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="上下文与 Token ROI" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="主动压缩（会话持久化层）" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.Settings.ContextCompaction.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="启用 truncate / compact 等会话级压缩"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="动态压缩（预算利用率）" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.Settings.ContextCompaction.DynamicCompaction.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="启用动态三级压缩策略"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="发送边界卫生（每轮 API 前）" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.Settings.ContextCompaction.RequestHistoryHygiene.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tool storm 抑制" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.Settings.ContextCompaction.ToolStorm.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Storm 阈值" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.Settings.ContextCompaction.ToolStorm.Threshold, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="MCP Search Mode" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox Content="启用 MCP 按需工具发现（search 模式）"
                                      IsChecked="{Binding Settings.Settings.McpSearch.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="模式 (direct/search/auto)" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.Settings.McpSearch.Mode, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Auto 阈值 (工具数)" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.Settings.McpSearch.AutoThresholdToolCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Auto 阈值 (schema 字符)" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.Settings.McpSearch.AutoThresholdSchemaChars, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Installed MCP Servers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Settings.McpConfigPath, StringFormat=MCP 服务从 {0} 读取；此页面仅控制每个服务是否启用。新增、删除和命令参数请直接修改 JSON 配置。}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding Settings.McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                                                    <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource Brush.PanelAlt}">
                                                        <TextBlock Text="{Binding DisplayInitial}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                    </Border>
                                                    <Ellipse Width="10" Height="10"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"
                                                             Margin="0,0,-2,-2"
                                                             Stroke="{DynamicResource Brush.Border}"
                                                             StrokeThickness="2">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource Brush.DisabledText}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStatusHealthy}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Danger}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ShowStatusDot}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ToolSummary}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>

                                                <CheckBox Grid.Column="2"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Installed Skills" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Settings.SkillsSettingsDescription}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding Settings.Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SkillItemViewModel}">
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.55" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="36"
                                                        Height="36"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource Brush.PanelAlt}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayInitial}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               FontSize="15" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <CheckBox Grid.Column="2"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="跳过目录" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="grep_files、glob_files、file_list 与侧栏工作区树会跳过这些目录名（路径任一段匹配即忽略）。每行一个，也可用逗号分隔。工作区单独配置 IgnorePatterns 时可覆盖此列表。"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,12" />
                            <TextBox Text="{Binding Settings.IgnoreDirectoriesText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     Margin="0,0,0,6" />
                            <TextBlock Text="默认包含 node_modules、dist、.next、build、bin、obj 等常见构建与依赖目录。"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="训练数据采集"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="自动从修正轨迹、溢出恢复轨迹、工具选型 DPO 中提取训练数据，写入 ~/.athlon-agent/training-data/。仅当 agent 调用工具失败→用户修正→重试成功、或超时→继续→完成时产出样本，不影响正常使用。"
                                           Foreground="{DynamicResource Brush.SubtleText}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      IsChecked="{Binding Settings.Settings.TrainingData.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="启用训练数据采集"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,24">
                        <TextBlock Text="{Binding SettingsStatus}" Foreground="{DynamicResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Scheduled Tasks -->
            <ScrollViewer Grid.Row="0"
                          Padding="40,32"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Brush.ChatBackground}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSchedulePage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel MaxWidth="760">
                    <!-- Top navigation bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Chat"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="返回对话"
                                Content="←" />
                        <TextBlock Text="定时任务"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="管理 AI Agent 定时执行的任务。"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <!-- Global toggle card -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏰" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center" />
                                    <TextBlock Text="定时任务"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding SchedulePageVm.TaskSummary}"
                                           Foreground="{DynamicResource Brush.SubtleText}"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding SchedulePageVm.IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      ToolTip="启用/禁用所有定时任务"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Filter chips and new task button -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding SchedulePageVm.FilterChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ScheduleFilterChipViewModel}">
                                    <Button Content="{Binding Label}"
                                            Margin="0,0,8,0"
                                            Command="{Binding DataContext.SchedulePageVm.SetFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Command="{Binding SchedulePageVm.NewTaskCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" />
                                <TextBlock Text="新建定时任务" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Empty state -->
                    <Border Background="{DynamicResource Brush.PanelAlt}">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SchedulePageVm.HasTasks}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="40">
                            <TextBlock Text="📅"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="暂无定时任务"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="点击上方「新建定时任务」按钮创建第一个任务，或告诉 AI Agent「每天 9 点提醒我」来自动创建。"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="400" />
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <ItemsControl ItemsSource="{Binding SchedulePageVm.Tasks}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SchedulePageVm.HasTasks}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleTaskItemViewModel}">
                                <Border Padding="20">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status icon -->
                                        <Border Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                CornerRadius="10"
                                                Background="{DynamicResource Brush.PanelAlt}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Task info -->
                                        <StackPanel Grid.Column="1" Margin="14,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ScheduleDescription}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.SubtleText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PromptPreview}"
                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                       FontSize="12"
                                                       Margin="0,6,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="400" />
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="下次: "
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.SubtleText}" />
                                                        <TextBlock Text="{Binding NextRunDisplay}"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding StatusIcon}"
                                                                   FontSize="11" />
                                                        <TextBlock Text="{Binding StatusDisplay}"
                                                                   FontSize="11"
                                                                   Margin="4,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding ToggleResultCommand}"
                                                    ToolTip="展开或收起运行结果"
                                                    Padding="8,4"
                                                    Margin="0,0,8,0"
                                                    FontSize="12">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Content" Value="显示运行结果" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasResult}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsResultExpanded}" Value="True">
                                                                <Setter Property="Content" Value="收起结果" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Command="{Binding RunCommand}"
                                                    ToolTip="立即执行"
                                                    Padding="8"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ComposerIconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="▶" FontSize="16" />
                                            </Button>
                                            <Button Command="{Binding CancelCommand}"
                                                    ToolTip="停止运行"
                                                    Padding="8"
                                                    Margin="0,0,4,0"
                                                    Foreground="{DynamicResource Brush.Danger}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ComposerIconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="■" FontSize="14" />
                                            </Button>
                                            <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource McpToggleSwitchStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="4,0" />
                                            <Button Command="{Binding EditCommand}"
                                                    ToolTip="编辑"
                                                    Style="{StaticResource ComposerIconButtonStyle}"
                                                    Padding="8"
                                                    Margin="4,0,4,0">
                                                <TextBlock Text="✎" FontSize="16" />
                                            </Button>
                                            <Button Command="{Binding DeleteCommand}"
                                                    ToolTip="删除"
                                                    Style="{StaticResource ComposerIconButtonStyle}"
                                                    Padding="8"
                                                    Foreground="{DynamicResource Brush.Danger}">
                                                <TextBlock Text="×" FontSize="16" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Result panel (expandable) -->
                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                            CornerRadius="8"
                                            Padding="14,12"
                                            Margin="0,12,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsResultExpanded}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding StatusIcon}" FontSize="11" />
                                                            <TextBlock Text="{Binding StatusDisplay}" FontSize="11" Margin="4,0,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Text="上次运行结果"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               VerticalAlignment="Center" />
                                                <Button Command="{Binding OpenSessionCommand}"
                                                        Content="查看对话"
                                                        Padding="8,4"
                                                        Margin="12,0,0,0"
                                                        FontSize="11"
                                                        VerticalAlignment="Center">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanOpenSession}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasLastRunTiming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="开始: "
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.SubtleText}" />
                                                            <TextBlock Text="{Binding LastRunStartDisplay}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="结束: "
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.SubtleText}" />
                                                            <TextBlock Text="{Binding LastRunEndDisplay}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource Brush.AppBackground}"
                                                    CornerRadius="6"
                                                    Padding="12,10">
                                                <TextBlock Text="{Binding LastMessage}"
                                                           FontSize="12"
                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Brush.Text}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- 底部状态栏（主区域右侧） -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{DynamicResource Brush.Chrome}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <TextBlock Text="{Binding Sidebar.LocalModelStatus, StringFormat=● {0}}"
                           Foreground="{DynamicResource Brush.Success}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Settings.Settings.Model.ModelName, StringFormat=模型: {0}}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               FontSize="12" />
                    <TextBlock Text="{Binding SessionUsageLine}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Text="{Binding LogsPath, StringFormat=Logs: {0}}"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding LogsPath}" />
            </Grid>
        </Border>

        <!-- Collapsed rail (Cursor-style edge affordance) -->
        <Border x:Name="ContextSidebarCollapsedRail"
                Grid.Row="1"
                Grid.Column="1"
                Width="28"
                HorizontalAlignment="Right"
                Background="{DynamicResource Brush.Chrome}"
                BorderThickness="0"
                Panel.ZIndex="2"
                Visibility="Collapsed"
                ToolTip="{Binding ContextSidebarToggleToolTip}">
            <Button Command="{Binding ToggleContextSidebarCommand}"
                    Style="{StaticResource RightSidebarToggleButtonStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,10,0,0"
                    ToolTip="{Binding ContextSidebarToggleToolTip}">
                <controls:RightSidebarToggleIcon IsPanelOpen="{Binding IsContextSidebarVisible}" />
            </Button>
        </Border>

        <!-- Context panel -->
        <Border x:Name="ContextSidebarPanel"
                Grid.Row="1"
                Grid.Column="2"
                Background="{DynamicResource Brush.AppBackground}"
                BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{x:Static app:AppLayoutMetrics.PanelHeaderRowHeight}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                    <Grid>
                        <TextBlock Text="上下文"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   VerticalAlignment="Center" />
                        <Button Command="{Binding ClearContextCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                ToolTip="清空当前对话在模型中的可见历史"
                                Style="{StaticResource IconButtonStyle}">
                            <TextBlock Text="🗑" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="1" Columns="2" Background="{DynamicResource Brush.Chrome}">
                    <RadioButton x:Name="ContextTabFiles"
                                 GroupName="ContextTabs"
                                 Content="文件"
                                 IsChecked="True"
                                 Style="{StaticResource ContextTabButtonStyle}" />
                    <RadioButton x:Name="ContextTabSkills"
                                 GroupName="ContextTabs"
                                 Content="技能"
                                 Style="{StaticResource ContextTabButtonStyle}" />
                </UniformGrid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=ContextTabFiles}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <!-- Files tab -->
                    <StackPanel>
                        <Border Background="{DynamicResource Brush.PanelAlt}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="工作区"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               FontSize="11"
                                               Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding ActiveWorkspaceName}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="配置"
                                        Command="{Binding ConfigureWorkspaceCommand}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="8,4"
                                        FontSize="12"
                                        MinHeight="28"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource Brush.Panel}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">
                            <TreeView ItemsSource="{Binding Sidebar.WorkspaceTree}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      FontSize="13"
                                      Foreground="{DynamicResource Brush.Text}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      MouseDoubleClick="WorkspaceTree_OnMouseDoubleClick">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource WorkspaceTreeViewItemStyle}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                        <EventSetter Event="Expanded" Handler="WorkspaceTreeItem_OnExpanded" />
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Style="{StaticResource MarkdownContextMenuStyle}">
                                                    <MenuItem Header="在编辑器中打开"
                                                              Style="{StaticResource MarkdownContextMenuItemStyle}"
                                                              Command="{Binding DataContext.OpenWorkspaceTreeNodeInEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="删除"
                                                              Style="{StaticResource MarkdownContextMenuItemStyle}"
                                                              Command="{Binding DataContext.DeleteWorkspaceItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanderPlaceholder}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Height" Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:WorkspaceFileIcon Kind="{Binding IconKind}" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=ContextTabSkills}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <!-- Skills + MCP tab -->
                    <StackPanel>
                        <TextBlock Text="技能" Foreground="{DynamicResource Brush.SubtleText}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource Brush.Panel}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding Sidebar.Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="0,4"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource Brush.Text}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                        <TextBlock Text="MCP 服务器" Foreground="{DynamicResource Brush.SubtleText}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource Brush.Panel}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10">
                            <ItemsControl ItemsSource="{Binding Sidebar.McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,3">
                                            <Button Command="{Binding ToggleExpandedCommand}"
                                                    Style="{StaticResource McpSidebarItemButtonStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Style="{StaticResource McpStatusIndicatorStyle}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" Style="{StaticResource McpStatusNameStyle}" />
                                                        <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Brush.SubtleText}"
                                                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Chevron}"
                                                               Foreground="{DynamicResource Brush.SubtleText}" FontSize="11"
                                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasTools}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                            <ItemsControl ItemsSource="{Binding ToolNames}" Margin="22,2,0,4">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.SubtleText}"
                                                                   FontSize="11" Margin="0,1" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter x:Name="NavigationSidebarSplitter"
                      Grid.Row="1"
                      Grid.Column="0"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3"
                      DragCompleted="NavigationSidebarSplitter_OnDragCompleted" />

        <GridSplitter x:Name="ContextSidebarSplitter"
                      Grid.Row="1"
                      Grid.Column="1"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3"
                      DragCompleted="ContextSidebarSplitter_OnDragCompleted" />
        </Grid>

        <Border Panel.ZIndex="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.45"
                                  BlurRadius="16"
                                  ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ToastNoticeStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCopyNoticeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding CopyNotice}"
                       Style="{StaticResource ToastNoticeTextStyle}" />
        </Border>

        <Border x:Name="ShutdownOverlay"
                Panel.ZIndex="200"
                Visibility="Collapsed"
                Background="{DynamicResource Brush.AppBackground}"
                Opacity="0.92">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="420">
                <TextBlock Text="正在关闭…"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock Text="{Binding ShutdownStatusText}"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
