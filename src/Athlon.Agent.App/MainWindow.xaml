<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athlon Agent" Height="768" Width="1366" MinHeight="720" MinWidth="1100"
        Background="{StaticResource Brush.AppBackground}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="114" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#0A0C0F" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <TextBlock DockPanel.Dock="Left" Text="Athlon Agent" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="14,7" Margin="4,0">
                        <TextBlock Text="{Binding CurrentSessionTitle}" />
                    </Border>
                    <Button Content="+"
                            Command="{Binding NewSessionCommand}"
                            Background="#101319"
                            BorderBrush="{StaticResource Brush.Border}"
                            Padding="12,7"
                            Margin="4,0"
                            MinWidth="36" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Background="#0A0C0F" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16" HorizontalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Brush.PanelAlt}" Margin="0,0,0,16">
                    <TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                </Border>
                <Button Content="Chat" Command="{Binding NavigateCommand}" CommandParameter="Chat" Margin="0,4" Width="64" />
                <Button Content="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings" Margin="0,4" Width="64" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="▣" FontSize="28" Foreground="{StaticResource Brush.SubtleText}" HorizontalAlignment="Center" Margin="0,0,0,14" />
                <TextBlock Text="How can I help you today?" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Enter a prompt below or use a skill to get started."
                           Foreground="{StaticResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <ScrollViewer Padding="36,24" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,14" MaxWidth="850" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                        <TextBlock Text="{Binding CreatedAt}" DockPanel.Dock="Right" Foreground="{StaticResource Brush.SubtleText}" FontSize="11" />
                                    </DockPanel>
                                    <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="0"
                                                                Foreground="{StaticResource Brush.Text}"
                                                                VerticalScrollBarVisibility="Disabled"
                                                                HorizontalScrollBarVisibility="Disabled" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="42,30" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel MaxWidth="760">
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="Configure model, logging, MCP, skills, workspace and tool permissions."
                           Foreground="{StaticResource Brush.SubtleText}"
                           Margin="0,0,0,24" />

                <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Model" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock Text="Provider" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Model.Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Endpoint" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Model.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Model Name" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Model.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="API Key" Foreground="{StaticResource Brush.SubtleText}" />
                        <PasswordBox x:Name="ApiKeyPasswordBox"
                                     PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged"
                                     Margin="0,6,0,6"
                                     Padding="12"
                                     Background="#181C22"
                                     Foreground="{StaticResource Brush.Text}"
                                     BorderBrush="{StaticResource Brush.Border}" />
                        <TextBlock Text="API Key is encrypted and stored locally with Windows DPAPI."
                                   Foreground="{StaticResource Brush.SubtleText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding HasStoredApiKey, StringFormat=Stored key exists: {0}}"
                                   Foreground="{StaticResource Brush.SubtleText}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Logging" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock Text="Directory" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Logging.Directory, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Minimum Level" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Logging.MinimumLevel, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Retained Days" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.Settings.Logging.RetainedDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Installed MCP Servers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <Border Background="{StaticResource Brush.PanelAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Settings.McpServers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1B1F25" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="46" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.ColumnSpan="2"
                                                            Command="{Binding DataContext.Settings.SelectMcpServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0"
                                                            HorizontalContentAlignment="Stretch">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="46" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="34" Height="34" CornerRadius="9" Background="#2A2F38" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding DisplayInitial}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding ToolSummary}" Foreground="#A3D977" Margin="0,4,0,0" />
                                                                <TextBlock Text="{Binding CommandSummary}" Foreground="{StaticResource Brush.SubtleText}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                              VerticalAlignment="Top"
                                                              Margin="16,4,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Command="{Binding Settings.AddMcpServerCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalContentAlignment="Stretch">
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="34" CornerRadius="9" Background="#2A2F38" HorizontalAlignment="Left">
                                            <TextBlock Text="+" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" Foreground="{StaticResource Brush.SubtleText}" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="New MCP Server" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="Add a Custom MCP Server" Foreground="{StaticResource Brush.SubtleText}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Background="#101319" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Selected MCP Server" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Name" Foreground="{StaticResource Brush.SubtleText}" />
                                <TextBox Text="{Binding Settings.SelectedMcpServer.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                <TextBlock Text="Command" Foreground="{StaticResource Brush.SubtleText}" />
                                <TextBox Text="{Binding Settings.SelectedMcpServer.Command, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                <TextBlock Text="Args" Foreground="{StaticResource Brush.SubtleText}" />
                                <TextBox Text="{Binding Settings.EditableMcpArgs, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                                <CheckBox Content="MCP Server Enabled"
                                          IsChecked="{Binding Settings.SelectedMcpServer.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          Foreground="{StaticResource Brush.Text}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Skills" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock Text="Skill Name" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.EditableSkill.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Skill Path" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.EditableSkill.Path, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <CheckBox Content="Skill Enabled"
                                  IsChecked="{Binding Settings.EditableSkill.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                  Foreground="{StaticResource Brush.Text}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Workspace" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock Text="Workspace Name" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.EditableWorkspace.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="Workspace Root Path" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBox Text="{Binding Settings.EditableWorkspace.RootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SettingsStatus}" Foreground="{StaticResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2" Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0" Padding="16">
            <StackPanel>
                <TextBlock Text="上下文面板" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16" />
                <Border Background="{StaticResource Brush.PanelAlt}" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="当前技能" Foreground="{StaticResource Brush.SubtleText}" />
                        <TextBlock Text="{Binding Sidebar.ActiveSkill}" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="Clean CSV/JSON/Excel files using pandas." Foreground="{StaticResource Brush.SubtleText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <TextBlock Text="内置工具" Foreground="{StaticResource Brush.SubtleText}" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding Sidebar.NativeTools}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat=● {0}}" Margin="0,3" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="MCP 服务器" Foreground="{StaticResource Brush.SubtleText}" Margin="0,18,0,8" />
                <ItemsControl ItemsSource="{Binding Sidebar.McpServers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,3" Foreground="#A3D977" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="工作区文件" Foreground="{StaticResource Brush.SubtleText}" Margin="0,18,0,8" />
                <ItemsControl ItemsSource="{Binding Sidebar.RecentFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat=▣ {0}}" Margin="0,3" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                MaxWidth="760"
                MinWidth="560"
                Margin="48,0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChatPage}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="32" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBox Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}" MinHeight="48" BorderThickness="0" />
                    <TextBlock Text="Message the agent, use @ to add a file, / for skills..."
                               Foreground="{StaticResource Brush.SubtleText}"
                               Margin="13,12,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsComposerEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Grid Grid.Row="1" Margin="4,8,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="{Binding ActiveWorkspaceName, StringFormat=工作区: {0}}"
                                Command="{Binding ConfigureWorkspaceCommand}"
                                Padding="10,4"
                                Margin="0,0,8,0" />
                        <TextBlock Text="@ 添加文件 / 技能  Ctrl+Enter 发送"
                                   Foreground="{StaticResource Brush.SubtleText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="停止" Command="{Binding StopCommand}" Margin="6,0,0,0" MinWidth="72" Padding="14,6" />
                        <Button Content="发送" Command="{Binding SendCommand}" Margin="6,0,0,0" MinWidth="72" Padding="14,6" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="10,0">
            <TextBlock Text="● Local Model Active" Foreground="#67C587" VerticalAlignment="Center" />
            <TextBlock DockPanel.Dock="Right" Text="Logs: %USERPROFILE%/AthlonAgent/logs" Foreground="{StaticResource Brush.SubtleText}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</Window>
