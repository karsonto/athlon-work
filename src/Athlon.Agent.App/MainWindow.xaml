<Window x:Class="Athlon.Agent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:app="clr-namespace:Athlon.Agent.App"
        xmlns:behaviors="clr-namespace:Athlon.Agent.App.Behaviors"
        xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
        xmlns:views="clr-namespace:Athlon.Agent.App.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athlon Agent"
        Icon="/Assets/app-icon.ico"
        Height="768"
        Width="1366"
        MinHeight="720"
        MinWidth="1100"
        Background="{DynamicResource Brush.AppBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control+Alt" Command="{Binding ToggleContextSidebarCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveActiveEditorCommand}" />
    </Window.InputBindings>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{x:Static app:AppLayoutMetrics.WindowChromeRowHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationSidebarColumn"
                              Width="280"
                              MinWidth="180"
                              MaxWidth="480" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ContextSidebarColumn"
                              Width="320"
                              MinWidth="220"
                              MaxWidth="560" />
        </Grid.ColumnDefinitions>

        <!-- Window chrome (minimize / maximize / close only) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource Brush.Chrome}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <i:Interaction.Behaviors>
                <behaviors:WindowChromeBehavior MaximizeRestoreButton="{Binding ElementName=MaximizeRestoreButton}" />
            </i:Interaction.Behaviors>
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,0">
                    <Image Source="/Assets/app-icon-48.png"
                           Width="16"
                           Height="16"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <Menu Style="{StaticResource TitleBarMenuStyle}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True"
                          VerticalAlignment="Stretch">
                        <MenuItem Header="Help"
                                  Style="{StaticResource TitleBarTopMenuItemStyle}">
                            <MenuItem Header="About"
                                      Click="HelpAboutMenuItem_OnClick" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Command="{Binding SsoLogoutCommand}"
                            ToolTip="点击退出登录"
                            Margin="0,0,4,0"
                            Padding="12,0"
                            MinWidth="46"
                            Height="32"
                            FontSize="13"
                            Foreground="{DynamicResource Brush.SubtleText}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Content" Value="{Binding SsoDisplayName}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSsoUserVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.HoverNeutral}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="−"
                            ToolTip="最小化"
                            Style="{StaticResource WindowCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="Minimize" />
                        </i:Interaction.Behaviors>
                    </Button>
                    <Button x:Name="MaximizeRestoreButton"
                            Content="□"
                            ToolTip="最大化"
                            Style="{StaticResource WindowCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="MaximizeRestore" />
                        </i:Interaction.Behaviors>
                    </Button>
                    <Button Content="×"
                            ToolTip="关闭"
                            Style="{StaticResource WindowCloseCaptionButtonStyle}">
                        <i:Interaction.Behaviors>
                            <behaviors:WindowCaptionButtonBehavior Action="Close" />
                        </i:Interaction.Behaviors>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left sidebar — session list -->
        <views:NavigationSidebarView Grid.Row="1" Grid.Column="0" />

        <!-- Main column: chat / settings + composer + footer -->
        <!-- Main column: lazy-loaded pages -->
        <ContentControl x:Name="PageHost"
                          Grid.Row="1"
                          Grid.Column="1"
                          Content="{Binding CurrentPageView}" />

        <!-- Context panel -->
        <Border x:Name="ContextSidebarPanel"
                Grid.Row="1"
                Grid.Column="2"
                Background="{DynamicResource Brush.AppBackground}"
                BorderThickness="0">
            <views:ContextSidebarView />
        </Border>

        <!-- 底部状态栏（主区域右侧） -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{DynamicResource Brush.Chrome}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <TextBlock Text="{Binding Sidebar.LocalModelStatus, StringFormat=● {0}}"
                           Foreground="{DynamicResource Brush.Success}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Settings.Settings.Model.ModelName, StringFormat=模型: {0}}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               FontSize="12" />
                    <TextBlock Text="{Binding SessionUsageLine}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Text="{Binding LogsPath, StringFormat=Logs: {0}}"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding LogsPath}" />
            </Grid>
        </Border>

        <!-- Collapsed rail (Cursor-style edge affordance) -->
        <Border x:Name="ContextSidebarCollapsedRail"
                Grid.Row="1"
                Grid.Column="1"
                Width="28"
                HorizontalAlignment="Right"
                Background="{DynamicResource Brush.Chrome}"
                BorderThickness="0"
                Panel.ZIndex="2"
                Visibility="Collapsed"
                ToolTip="{Binding ContextSidebarToggleToolTip}">
            <Button Command="{Binding ToggleContextSidebarCommand}"
                    Style="{StaticResource RightSidebarToggleButtonStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,10,0,0"
                    ToolTip="{Binding ContextSidebarToggleToolTip}">
                <controls:RightSidebarToggleIcon IsPanelOpen="{Binding IsContextSidebarVisible}" />
            </Button>
        </Border>

        <!-- Context panel -->

        <GridSplitter x:Name="NavigationSidebarSplitter"
                      Grid.Row="1"
                      Grid.Column="0"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3">
            <i:Interaction.Behaviors>
                <behaviors:GridSplitterLayoutBehavior Kind="NavigationSidebar" />
            </i:Interaction.Behaviors>
        </GridSplitter>

        <GridSplitter x:Name="ContextSidebarSplitter"
                      Grid.Row="1"
                      Grid.Column="1"
                      Style="{StaticResource LayoutColumnSplitterStyle}"
                      ResizeDirection="Columns"
                      ResizeBehavior="CurrentAndNext"
                      Panel.ZIndex="3">
            <i:Interaction.Behaviors>
                <behaviors:GridSplitterLayoutBehavior Kind="ContextSidebar" />
            </i:Interaction.Behaviors>
        </GridSplitter>
        </Grid>

        <Border Panel.ZIndex="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.45"
                                  BlurRadius="16"
                                  ShadowDepth="4"
                                  Direction="270" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ToastNoticeStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCopyNoticeVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding CopyNotice}"
                       Style="{StaticResource ToastNoticeTextStyle}" />
        </Border>

        <Border x:Name="ShutdownOverlay"
                Panel.ZIndex="200"
                Visibility="Collapsed"
                Background="{DynamicResource Brush.AppBackground}"
                Opacity="0.92">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="420">
                <TextBlock Text="正在关闭…"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock Text="{Binding ShutdownStatusText}"
                           FontSize="14"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
