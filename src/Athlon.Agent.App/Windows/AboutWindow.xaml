<Window x:Class="Athlon.Agent.App.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="About Athlon Agent"
        Icon="/Assets/app-icon.ico"
        Height="400"
        Width="440"
        MinHeight="320"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.AppBackground}"
        WindowStyle="None">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            Background="{DynamicResource Brush.AppBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Chrome}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid Margin="12,0">
                    <TextBlock Text="About Athlon Agent"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right"
                            ToolTip="关闭"
                            Click="CloseButton_OnClick"
                            ContentTemplate="{StaticResource WindowCaptionCloseIconTemplate}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource WindowCloseCaptionButtonStyle}" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="32,24">
                <Image Source="/Assets/app-icon-128.png"
                       Width="72"
                       Height="72"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock x:Name="ProductNameText"
                           Text="Athlon Agent"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Text}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,4" />
                <TextBlock x:Name="VersionText"
                           FontSize="13"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="AI coding agent for your workspace."
                           FontSize="13"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
                <TextBlock Text="如有问题，请联系 FTD AMS 团队。"
                           FontSize="12"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
                <TextBlock x:Name="UpdateStatusText"
                           FontSize="12"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.AppBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Button Content="检查更新"
                            HorizontalAlignment="Left"
                            MinWidth="96"
                            Click="CheckUpdateButton_OnClick"
                            Style="{StaticResource GhostButtonStyle}" />
                    <Button Content="确定"
                            HorizontalAlignment="Right"
                            MinWidth="88"
                            IsDefault="True"
                            Click="CloseButton_OnClick"
                            Style="{StaticResource GhostButtonStyle}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
