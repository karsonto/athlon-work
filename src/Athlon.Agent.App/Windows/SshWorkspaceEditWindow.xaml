<Window x:Class="Athlon.Agent.App.Windows.SshWorkspaceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
        Title="{loc:Localize Key=Shell_SshWorkspaceTitle}"
        Width="520"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppBackground}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{loc:Localize Key=Shell_SshWorkspaceTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{loc:Localize Key=Shell_SshName}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="NameBox" Padding="10,8" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Localize Key=Shell_SshHost}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="HostBox" Padding="10,8" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Localize Key=Shell_SshPort}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="PortBox" Text="22" Padding="10,8" Width="120" HorizontalAlignment="Left" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Localize Key=Shell_SshUsername}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="UsernameBox" Padding="10,8" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Localize Key=Shell_SshRemoteRoot}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="RemoteRootBox" Text="/home" Padding="10,8" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Localize Key=Shell_SshAuthMode}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="AuthModeCombo" Margin="0,0,0,14" SelectionChanged="AuthModeCombo_OnSelectionChanged">
                    <ComboBoxItem Tag="password" Content="{loc:Localize Key=Shell_SshAuthPassword}" IsSelected="True" />
                    <ComboBoxItem Tag="privateKey" Content="{loc:Localize Key=Shell_SshAuthPrivateKey}" />
                </ComboBox>

                <StackPanel x:Name="PasswordPanel">
                    <TextBlock Text="{loc:Localize Key=Shell_SshPassword}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PasswordBox" Padding="10,8" Margin="0,0,0,14" />
                </StackPanel>

                <StackPanel x:Name="PrivateKeyPanel" Visibility="Collapsed">
                    <TextBlock Text="{loc:Localize Key=Shell_SshPrivateKeyPath}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right"
                                Content="…"
                                Width="40"
                                Margin="8,0,0,0"
                                Click="BrowseKeyButton_Click" />
                        <TextBox x:Name="PrivateKeyPathBox" Padding="10,8" />
                    </DockPanel>
                    <TextBlock Text="{loc:Localize Key=Shell_SshKeyPassphrase}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PassphraseBox" Padding="10,8" Margin="0,0,0,14" />
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           Margin="0,0,0,8" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:Localize Key=Shell_SshTestConnection}"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    Click="TestButton_Click" />
            <Button Content="{loc:Localize Key=Common_Cancel}"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="{loc:Localize Key=Common_OK}"
                    Padding="16,8"
                    IsDefault="True"
                    Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>
