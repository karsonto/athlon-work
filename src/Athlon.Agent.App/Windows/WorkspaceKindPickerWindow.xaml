<Window x:Class="Athlon.Agent.App.Windows.WorkspaceKindPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
        Title="{loc:Localize Key=Shell_SelectWorkspace}"
        Width="420"
        Height="220"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppBackground}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{loc:Localize Key=Shell_WorkspaceKindPrompt}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Button Content="{loc:Localize Key=Shell_WorkspaceKindLocal}"
                    Padding="12,10"
                    Margin="0,0,0,10"
                    Click="LocalButton_Click" />
            <Button Content="{loc:Localize Key=Shell_WorkspaceKindSsh}"
                    Padding="12,10"
                    Click="SshButton_Click" />
        </StackPanel>

        <Button Grid.Row="2"
                Content="{loc:Localize Key=Common_Cancel}"
                HorizontalAlignment="Right"
                Padding="16,8"
                Margin="0,16,0,0"
                IsCancel="True"
                Click="CancelButton_Click" />
    </Grid>
</Window>
