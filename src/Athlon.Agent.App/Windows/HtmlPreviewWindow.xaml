<Window x:Class="Athlon.Agent.App.Windows.HtmlPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="HTML 预览"
        Width="1200"
        Height="820"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource PreviewWindowStyle}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12"
              MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <StackPanel>
                <TextBlock Text="HTML 预览"
                           Style="{StaticResource PreviewWindowTitleStyle}" />
                <TextBlock Text="已在沙箱环境中渲染，不会影响当前页面"
                           Style="{StaticResource PreviewWindowSubtitleStyle}" />
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="CloseButton_OnClick"
                    ToolTip="关闭"
                    ContentTemplate="{StaticResource WindowCaptionCloseIconTemplate}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Style="{StaticResource WindowCloseCaptionButtonStyle}" />
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource PreviewContentFrameStyle}">
            <wv2:WebView2 x:Name="PreviewWebView" />
        </Border>
    </Grid>
</Window>
