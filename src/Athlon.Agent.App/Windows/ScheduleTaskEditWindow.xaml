<Window x:Class="Athlon.Agent.App.Windows.ScheduleTaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
        Title="{loc:Localize Key=Schedule_EditTitle}"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppBackground}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Text="{loc:Localize Key=Schedule_EditTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{loc:Localize Key=Schedule_TaskName}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TitleBox" Padding="10,8" Margin="0,0,0,16" />

                <TextBlock Text="{loc:Localize Key=Schedule_Workspace}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="{loc:Localize Key=Schedule_WorkspaceRequired}"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           FontSize="11"
                           Margin="0,0,0,6" />
                <TextBox x:Name="WorkspaceBox" Padding="10,8" Margin="0,0,0,16" />

                <TextBlock Text="{loc:Localize Key=Schedule_Prompt}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="PromptBox"
                         Padding="10,8"
                         Margin="0,0,0,16"
                         MinHeight="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />

                <TextBlock Text="{loc:Localize Key=Schedule_Kind}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="KindCombo"
                          Margin="0,0,0,16">
                    <ComboBoxItem Tag="daily" Content="{loc:Localize Key=Schedule_KindDaily}" />
                    <ComboBoxItem Tag="interval" Content="{loc:Localize Key=Schedule_KindInterval}" />
                    <ComboBoxItem Tag="at" Content="{loc:Localize Key=Schedule_KindAt}" />
                    <ComboBoxItem Tag="manual" Content="{loc:Localize Key=Schedule_KindManual}" />
                </ComboBox>

                <Border x:Name="DailyPanel"
                        Background="{DynamicResource Brush.Panel}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Key=Schedule_TimeOfDay}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="TimeOfDayBox" Text="09:00" Padding="10,8" Width="120" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border x:Name="IntervalPanel"
                        Background="{DynamicResource Brush.Panel}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Key=Schedule_IntervalMinutes}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="IntervalBox" Text="60" Padding="10,8" Width="120" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border x:Name="AtPanel"
                        Background="{DynamicResource Brush.Panel}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Key=Schedule_AtTime}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="AtTimeBox" Padding="10,8" Width="220" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{loc:Localize Key=Common_Cancel}"
                    IsCancel="True"
                    Style="{StaticResource GhostButtonStyle}"
                    Margin="0,0,12,0" />
            <Button x:Name="SaveButton"
                    Content="{loc:Localize Key=Common_Save}"
                    Click="SaveButton_Click"
                    Style="{StaticResource GhostButtonStyle}"
                    Foreground="{DynamicResource Brush.Accent}" />
        </StackPanel>
    </Grid>
</Window>
