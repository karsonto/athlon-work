<Window x:Class="Athlon.Agent.App.Licensing.ImpSsoLoginWaitingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMP SSO 登录"
        Icon="/Assets/app-icon.ico"
        Height="220"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{DynamicResource Brush.AppBackground}">
    <StackPanel Margin="28" VerticalAlignment="Center">
        <TextBlock Text="正在等待 IMP 登录"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" />
        <TextBlock Text="已在浏览器中打开登录页面，请完成登录。"
                   Margin="0,14,0,0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SubtleText}" />
        <TextBlock Text="登录成功后此窗口将自动关闭，主界面随后出现。"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SubtleText}" />
    </StackPanel>
</Window>
