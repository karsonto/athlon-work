<UserControl x:Class="Athlon.Agent.App.Views.SchedulePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization">
    <ScrollViewer Padding="40,32" VerticalScrollBarVisibility="Auto" Background="{DynamicResource Brush.ChatBackground}">
                <StackPanel MaxWidth="760">
                    <!-- Top navigation bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Chat"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="{loc:Localize Key=Common_BackToChat}"
                                Content="←" />
                        <ContentControl Style="{StaticResource ScheduleNavIconStyle}"
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Localize Key=Schedule_Title}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{loc:Localize Key=Schedule_Subtitle}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <!-- Global toggle card -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ContentControl Style="{StaticResource ScheduleNavIconStyle}"
                                                    Width="26"
                                                    Height="26"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Localize Key=Schedule_Title}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding SchedulePageVm.TaskSummary}"
                                           Foreground="{DynamicResource Brush.SubtleText}"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding SchedulePageVm.IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      ToolTip="{loc:Localize Key=Schedule_ToggleAllTooltip}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Filter chips and new task button -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding SchedulePageVm.FilterChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ScheduleFilterChipViewModel}">
                                    <Button Content="{Binding Label}"
                                            Margin="0,0,8,0"
                                            Command="{Binding DataContext.SchedulePageVm.SetFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Command="{Binding SchedulePageVm.NewTaskCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Localize Key=Schedule_NewTask}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Empty state -->
                    <Border Background="{DynamicResource Brush.PanelAlt}">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SchedulePageVm.HasTasks}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="40">
                            <TextBlock Text="📅"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="0,0,0,16" />
                            <TextBlock Text="{loc:Localize Key=Schedule_NoTasks}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{loc:Localize Key=Schedule_NoTasksHint}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="400" />
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <ItemsControl ItemsSource="{Binding SchedulePageVm.Tasks}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SchedulePageVm.HasTasks}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleTaskItemViewModel}">
                                <Border Padding="20">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status icon -->
                                        <Border Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                CornerRadius="10"
                                                Background="{DynamicResource Brush.PanelAlt}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Task info -->
                                        <StackPanel Grid.Column="1" Margin="14,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ScheduleDescription}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.SubtleText}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PromptPreview}"
                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                       FontSize="12"
                                                       Margin="0,6,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="400" />
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{loc:Localize Key=Schedule_NextRun}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.SubtleText}" />
                                                        <TextBlock Text="{Binding NextRunDisplay}"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{DynamicResource Brush.PanelAlt}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding StatusIcon}"
                                                                   FontSize="11" />
                                                        <TextBlock Text="{Binding StatusDisplay}"
                                                                   FontSize="11"
                                                                   Margin="4,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding ToggleResultCommand}"
                                                    ToolTip="{loc:Localize Key=Schedule_ExpandResultTooltip}"
                                                    Padding="8,4"
                                                    Margin="0,0,8,0"
                                                    FontSize="12">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Content" Value="{loc:Localize Key=Schedule_ShowResult}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasResult}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsResultExpanded}" Value="True">
                                                                <Setter Property="Content" Value="{loc:Localize Key=Schedule_HideResult}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Command="{Binding RunCommand}"
                                                    ToolTip="{loc:Localize Key=Schedule_RunNowTooltip}"
                                                    Padding="8"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ComposerIconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="▶" FontSize="16" />
                                            </Button>
                                            <Button Command="{Binding CancelCommand}"
                                                    ToolTip="{loc:Localize Key=Schedule_StopTooltip}"
                                                    Padding="8"
                                                    Margin="0,0,4,0"
                                                    Foreground="{DynamicResource Brush.Danger}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ComposerIconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="■" FontSize="14" />
                                            </Button>
                                            <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource McpToggleSwitchStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="4,0" />
                                            <Button Command="{Binding EditCommand}"
                                                    ToolTip="{loc:Localize Key=Schedule_EditTooltip}"
                                                    Style="{StaticResource ComposerIconButtonStyle}"
                                                    Padding="8"
                                                    Margin="4,0,4,0">
                                                <TextBlock Text="✎" FontSize="16" />
                                            </Button>
                                            <Button Command="{Binding DeleteCommand}"
                                                    ToolTip="{loc:Localize Key=Schedule_DeleteTooltip}"
                                                    Style="{StaticResource ComposerIconButtonStyle}"
                                                    Padding="8"
                                                    Foreground="{DynamicResource Brush.Danger}">
                                                <TextBlock Text="×" FontSize="16" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Result panel (expandable) -->
                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                            CornerRadius="8"
                                            Padding="14,12"
                                            Margin="0,12,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsResultExpanded}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding StatusIcon}" FontSize="11" />
                                                            <TextBlock Text="{Binding StatusDisplay}" FontSize="11" Margin="4,0,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Text="{loc:Localize Key=Schedule_LastResult}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               VerticalAlignment="Center" />
                                                <Button Command="{Binding OpenSessionCommand}"
                                                        Content="{loc:Localize Key=Schedule_ViewConversation}"
                                                        Padding="8,4"
                                                        Margin="12,0,0,0"
                                                        FontSize="11"
                                                        VerticalAlignment="Center">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanOpenSession}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasLastRunTiming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{loc:Localize Key=Schedule_StartLabel}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.SubtleText}" />
                                                            <TextBlock Text="{Binding LastRunStartDisplay}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource Brush.PanelAlt}"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{loc:Localize Key=Schedule_EndLabel}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Brush.SubtleText}" />
                                                            <TextBlock Text="{Binding LastRunEndDisplay}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource Brush.AppBackground}"
                                                    CornerRadius="6"
                                                    Padding="12,10">
                                                <TextBlock Text="{Binding LastMessage}"
                                                           FontSize="12"
                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Brush.Text}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
    </ScrollViewer>
</UserControl>
