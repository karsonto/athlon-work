<UserControl x:Class="Athlon.Agent.App.Views.NavigationSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Athlon.Agent.App"
             xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
             xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/ChatNavIconStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="12,10,12,8">
                <Button Command="{Binding ToggleNavigationSidebarCommand}"
                        Style="{StaticResource RightSidebarToggleButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,10"
                        ToolTip="{Binding NavigationSidebarToggleToolTip}">
                    <controls:LeftSidebarToggleIcon Foreground="{DynamicResource Brush.SubtleText}"
                                                    IsPanelOpen="{Binding IsNavigationSidebarVisible}" />
                </Button>
                <Button Command="{Binding NewSessionCommand}"
                        ToolTip="{loc:Localize Key=Nav_NewSessionTooltip}"
                        Style="{StaticResource NewSessionButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Localize Key=Nav_NewAgent}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="{loc:Localize Key=Nav_NoAgentRecords}"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="4,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="{loc:Localize Key=Nav_Repositories}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.DisabledText}"
                               Margin="4,4,4,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding AgentRecordGroups}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AgentRecordGroupViewModel}">
                                <StackPanel Margin="0,0,0,4">
                                    <Button Command="{Binding ToggleExpandedCommand}"
                                            Style="{StaticResource AgentRecordGroupHeaderStyle}"
                                            ToolTip="{Binding WorkspacePath}">
                                        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FolderGlyph}"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="13"
                                                       Margin="0,0,8,0"
                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource Brush.Text}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="4,0,0,4">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SessionHistoryItemViewModel}">
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource SessionItemBorderStyle}">
                                                            <Setter Property="Padding" Value="10,8" />
                                                            <Setter Property="Margin" Value="0,0,0,2" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHover}" />
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0"
                                                                Command="{Binding DataContext.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SessionHistoryButtonStyle}"
                                                                Padding="0,0,8,0"
                                                                HorizontalContentAlignment="Stretch">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Style="{StaticResource SessionNameTextStyle}"
                                                                       ToolTip="{Binding StatusText}" />
                                                        </Button>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding MetaText}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Brush.SubtleText}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0" />
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Button Command="{Binding StopSessionCommand}"
                                                                    Content="■"
                                                                    ToolTip="{loc:Localize Key=Nav_StopGeneration}"
                                                                    Foreground="{DynamicResource Brush.Warning}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource SessionActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    ToolTip="{loc:Localize Key=Common_Delete}"
                                                                    Style="{StaticResource SessionActionButtonStyle}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="12,0,12,0">
                <Border Background="{DynamicResource Brush.PanelAlt}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQueuedTurns}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Key=Nav_Queued}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.SubtleText}"
                                   Margin="0,0,0,6" />
                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QueuedTurns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:QueuedTurnViewModel}">
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8,8"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding PreviewText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource Brush.Text}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="40">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PreviewText}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ItemsControl ItemsSource="{Binding ImageItems}" Margin="0,6,0,0">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasImages}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:QueuedTurnImageViewModel}">
                                                                <Border Width="44"
                                                                        Height="44"
                                                                        CornerRadius="8"
                                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                                        BorderThickness="1"
                                                                        Background="{DynamicResource Brush.PanelAlt}"
                                                                        Margin="0,0,8,0"
                                                                        ToolTip="{Binding FileName}">
                                                                    <Grid>
                                                                        <Image Source="{Binding Thumbnail}"
                                                                               Stretch="UniformToFill"
                                                                               Margin="2" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="×"
                                                        Command="{Binding DataContext.RemoveQueuedTurnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{loc:Localize Key=Nav_RemoveFromQueue}"
                                                        Style="{StaticResource SessionDeleteButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Brush.PanelAlt}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ComposerHarness.ShowTaskPanel}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Key=Nav_TaskPlan}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.SubtleText}"
                                   Margin="0,0,0,6" />
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ComposerHarness.Tasks}" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Knowledge navigation button -->
                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="Knowledge"
                        Style="{StaticResource NavBottomButtonStyle}"
                        ToolTip="{loc:Localize Key=Nav_Knowledge}"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource KnowledgeNavIconStyle}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Localize Key=Nav_Knowledge}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Schedule navigation button -->
                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="Schedule"
                        Style="{StaticResource NavBottomButtonStyle}"
                        ToolTip="{loc:Localize Key=Nav_Schedule}">
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource ScheduleNavIconStyle}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Localize Key=Nav_Schedule}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Account pinned at bottom so maximize / short heights keep login visible -->
            <Border Grid.Row="3"
                    Style="{StaticResource SidebarAccountBarStyle}"
                    Margin="12,0,12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding SsoLogoutCommand}"
                                HorizontalContentAlignment="Left"
                                ToolTip="{loc:Localize Key=Sso_LogoutTooltip}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarAccountIdentityButtonStyle}">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSsoUserVisible}" Value="True">
                                            <Setter Property="IsEnabled" Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="28"
                                        Height="28"
                                        CornerRadius="14"
                                        Background="{DynamicResource Brush.Accent}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SsoAvatarInitial}"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SidebarAccountTitle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SidebarAccountSubtitle}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Settings"
                                Style="{StaticResource SidebarAccountSettingsButtonStyle}"
                                ToolTip="{loc:Localize Key=Chat_SettingsTooltip}"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
