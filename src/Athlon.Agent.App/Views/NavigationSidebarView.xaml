<UserControl x:Class="Athlon.Agent.App.Views.NavigationSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Athlon.Agent.App"
             xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
             xmlns:controls="clr-namespace:Athlon.Agent.App.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/ChatNavIconStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{x:Static app:AppLayoutMetrics.PanelHeaderRowHeight}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/app-icon-48.png"
                               Width="24"
                               Height="24"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Athlon" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Command="{Binding NewSessionCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="新建会话"
                            Style="{StaticResource NewSessionButtonStyle}">
                        <TextBlock Text="+" FontSize="16" FontWeight="SemiBold" Margin="0,-1,0,0" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="暂无 Agent 记录"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="12,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding AgentRecordGroups}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAgentRecords}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AgentRecordGroupViewModel}">
                                <StackPanel>
                                    <Button Command="{Binding ToggleExpandedCommand}"
                                            Style="{StaticResource AgentRecordGroupHeaderStyle}">
                                        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ExpandGlyph}"
                                                       FontSize="10"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.DisabledText}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Items.Count}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SessionHistoryItemViewModel}">
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource SessionItemBorderStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="BorderThickness" Value="3,1,1,1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 Margin="0,0,10,0"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{DynamicResource Brush.SubtleText}">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SessionHistoryButtonStyle}"
                                                                Padding="0,0,8,0">
                                                            <StackPanel HorizontalAlignment="Stretch">
                                                                <TextBlock Text="{Binding Title}" Style="{StaticResource SessionNameTextStyle}" />
                                                                <TextBlock Text="{Binding MetaText}" Style="{StaticResource SessionMetaTextStyle}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Button Command="{Binding StopSessionCommand}"
                                                                    Content="■"
                                                                    ToolTip="停止生成"
                                                                    Foreground="{DynamicResource Brush.Warning}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource SessionActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    ToolTip="删除"
                                                                    Style="{StaticResource SessionActionButtonStyle}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="12,0,12,12">
                <Border Background="{DynamicResource Brush.PanelAlt}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQueuedTurns}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="排队中"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.SubtleText}"
                                   Margin="0,0,0,6" />
                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QueuedTurns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:QueuedTurnViewModel}">
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8,8"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding PreviewText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource Brush.Text}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="40">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PreviewText}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ItemsControl ItemsSource="{Binding ImageItems}" Margin="0,6,0,0">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasImages}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:QueuedTurnImageViewModel}">
                                                                <Border Width="44"
                                                                        Height="44"
                                                                        CornerRadius="8"
                                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                                        BorderThickness="1"
                                                                        Background="{DynamicResource Brush.PanelAlt}"
                                                                        Margin="0,0,8,0"
                                                                        ToolTip="{Binding FileName}">
                                                                    <Grid>
                                                                        <Image Source="{Binding Thumbnail}"
                                                                               Stretch="UniformToFill"
                                                                               Margin="2" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="×"
                                                        Command="{Binding DataContext.RemoveQueuedTurnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="从队列移除"
                                                        Style="{StaticResource SessionDeleteButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Knowledge navigation button -->
                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="Knowledge"
                        Style="{StaticResource NavBottomButtonStyle}"
                        ToolTip="知识库"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource KnowledgeNavIconStyle}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="知识库" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Schedule navigation button -->
                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="Schedule"
                        Style="{StaticResource NavBottomButtonStyle}"
                        ToolTip="定时任务">
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource ScheduleNavIconStyle}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="定时任务" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
