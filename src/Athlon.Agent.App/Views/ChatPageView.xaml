<UserControl x:Class="Athlon.Agent.App.Views.ChatPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Athlon.Agent.App"
             xmlns:behaviors="clr-namespace:Athlon.Agent.App.Behaviors"
             xmlns:controls="clr-namespace:Athlon.Agent.App.Controls"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
             xmlns:harness="clr-namespace:Athlon.Agent.Core.Harness;assembly=Athlon.Agent.Core">
    <Grid Background="{DynamicResource Brush.ChatBackground}" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="EditorPaneColumn" Width="0" MinWidth="0" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="EditorPaneHost"
                        Grid.Column="0"
                        Background="{DynamicResource Brush.AppBackground}"
                        BorderThickness="0"
                        Visibility="Collapsed">
                    <Grid>
                        <controls:FileEditorView DataContext="{Binding FileEditor}" />
                    </Grid>
                </Border>

                <GridSplitter x:Name="EditorChatSplitter"
                              Grid.Column="0"
                              Style="{StaticResource LayoutColumnSplitterStyle}"
                              ResizeDirection="Columns"
                              ResizeBehavior="CurrentAndNext"
                              Panel.ZIndex="2"
                              Visibility="Collapsed">
                    <i:Interaction.Behaviors>
                        <behaviors:GridSplitterLayoutBehavior Kind="EditorPane" />
                    </i:Interaction.Behaviors>
                </GridSplitter>

                <Grid Grid.Column="1" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="{Binding ContextSidebarEdgeGutterWidth}" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{x:Static app:AppLayoutMetrics.PanelHeaderRowHeight}" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition x:Name="ComposerRow"
                                   Height="168"
                                   MinHeight="120"
                                   MaxHeight="420" />
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Height="{x:Static app:AppLayoutMetrics.PanelHeaderHeight}"
                        Background="{DynamicResource Brush.Chrome}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="24,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,12,0" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding ToggleThemeCommand}"
                                    ToolTip="{Binding ThemeToggleToolTip}"
                                    Style="{StaticResource HeaderIconButtonStyle}"
                                    AutomationProperties.Name="{Binding ThemeToggleToolTip}">
                                <Button.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLightTheme}" Value="False">
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="{Binding ThemeToggleGlyph}"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </Button>
                            <Button Command="{Binding NavigateCommand}"
                                    CommandParameter="Settings"
                                    ToolTip="{loc:Localize Key=Chat_SettingsTooltip}"
                                    Style="{StaticResource HeaderIconButtonStyle}"
                                    Margin="4,0,0,0">
                                <Button.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLightTheme}" Value="False">
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="&#xE713;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" />
                            </Button>
                            <Button Command="{Binding ToggleContextSidebarCommand}"
                                    Style="{StaticResource HeaderIconButtonStyle}"
                                    Foreground="#FF2563EB"
                                    Margin="4,0,0,0"
                                    ToolTip="{Binding ContextSidebarToggleToolTip}">
                                <controls:RightSidebarToggleIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                 IsPanelOpen="{Binding IsContextSidebarVisible}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Grid.Column="0"
                      ClipToBounds="True">
                <!-- WebView2 聊天渲染器：始终保持可见，避免 Collapsed 导致 WebView2 无法渲染 -->
                <controls:WebChatView x:Name="ChatWebView"
                                      Margin="0"
                                      ClipToBounds="True"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />

                <!-- Loading indicator -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Panel.ZIndex="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingSession}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="⏳"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Opacity="0.7"
                               Margin="0,0,0,12" />
                    <TextBlock Text="{loc:Localize Key=Chat_LoadingConversation}"
                               FontSize="16"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>
                </Grid>
                <GridSplitter x:Name="ComposerSplitter"
                              Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Style="{StaticResource LayoutRowSplitterStyle}"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Panel.ZIndex="2">
                    <i:Interaction.Behaviors>
                        <behaviors:GridSplitterLayoutBehavior Kind="Composer" />
                    </i:Interaction.Behaviors>
                </GridSplitter>

            <!-- Composer -->
            <Border Grid.Row="3"
                    Panel.ZIndex="20"
                    Style="{StaticResource ComposerOuterBorderStyle}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.75*" MinWidth="12" />
                        <ColumnDefinition Width="8.5*"
                                          MaxWidth="{x:Static app:AppLayoutMetrics.ComposerMaxContentWidth}" />
                        <ColumnDefinition Width="0.75*" MinWidth="12" />
                    </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        x:Name="ComposerInputWrapper"
                        Style="{StaticResource ComposerInputWrapperStyle}"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="56" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0,0,0,6">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingImages}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding PendingImageAttachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.PanelAlt}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,8,0"
                                                Padding="6,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="40"
                                                        Height="40"
                                                        CornerRadius="8"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource Brush.Panel}"
                                                        Margin="0,0,8,0">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           Margin="2" />
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding FileName}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="2"
                                                        Content="×"
                                                        Command="{Binding DataContext.RemovePendingImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SessionDeleteButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <controls:ComposerInputControl x:Name="ComposerInput"
                                                       Grid.Row="1" />
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Button Command="{Binding SelectImagesCommand}"
                                            Style="{StaticResource ComposerToolButtonStyle}"
                                            ToolTip="{loc:Localize Key=Chat_UploadImageTooltip}">
                                        <Grid Width="12" Height="12">
                                            <Rectangle Width="12"
                                                       Height="1.5"
                                                       RadiusX="0.75"
                                                       RadiusY="0.75"
                                                       VerticalAlignment="Center"
                                                       Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                            <Rectangle Width="1.5"
                                                       Height="12"
                                                       RadiusX="0.75"
                                                       RadiusY="0.75"
                                                       HorizontalAlignment="Center"
                                                       Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                        </Grid>
                                    </Button>
                                    <Button x:Name="KnowledgePickerButton"
                                            Command="{Binding ComposerKnowledge.ToggleKnowledgePickerCommand}"
                                            Margin="8,0,0,0"
                                            Padding="10,5"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding ComposerKnowledge.IsKnowledgeButtonEnabled}"
                                            ToolTip="{Binding ComposerKnowledge.KnowledgeButtonToolTip}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ComposerKnowledge.IsKnowledgeActive}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHover}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.45" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M5,5 L19,5 A1,1 0 0 1 20,6 L20,18 A1,1 0 0 1 19,19 L5,19 A1,1 0 0 1 4,18 L4,6 A1,1 0 0 1 5,5 Z M6,6 L6,18 L18,18 L18,6 Z M8,9 L16,9 M8,12 L16,12 M8,15 L13,15"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.3"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Width="15"
                                                  Height="15"
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ComposerKnowledge.KnowledgePickerLabel}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="HarnessModePickerButton"
                                            Command="{Binding ComposerHarness.ToggleModePickerCommand}"
                                            Margin="8,0,0,0"
                                            Padding="10,5"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding ComposerHarness.HarnessButtonToolTip}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ComposerHarness.IsHarnessActive}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHover}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M4,6 L20,6 M4,12 L20,12 M4,18 L14,18"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Width="16"
                                                  Height="16"
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ComposerHarness.HarnessPickerLabel}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Popup PlacementTarget="{Binding ElementName=HarnessModePickerButton}"
                                       Placement="Top"
                                       IsOpen="{Binding ComposerHarness.IsModePickerOpen, Mode=TwoWay}"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{DynamicResource Brush.Panel}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8"
                                            MinWidth="200">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Localize Key=Harness_Picker_SelectMode}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                                                    CommandParameter="{x:Static harness:SessionAgentMode.Agent}"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="10,8"
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource GhostButtonStyle}">
                                                <Grid Width="160">
                                                    <TextBlock Text="{loc:Localize Key=Harness_Mode_Agent}" />
                                                    <TextBlock Text="✓" HorizontalAlignment="Right" Visibility="Collapsed">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}" Value="{x:Static harness:SessionAgentMode.Agent}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                            <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                                                    CommandParameter="{x:Static harness:SessionAgentMode.Coding}"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="10,8"
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource GhostButtonStyle}">
                                                <Grid Width="160">
                                                    <TextBlock Text="{loc:Localize Key=Harness_Mode_Coding}" />
                                                    <TextBlock Text="✓" HorizontalAlignment="Right" Visibility="Collapsed">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}" Value="{x:Static harness:SessionAgentMode.Coding}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                            <Button Command="{Binding ComposerHarness.SelectModeCommand}"
                                                    CommandParameter="{x:Static harness:SessionAgentMode.Ask}"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="10,8"
                                                    Style="{StaticResource GhostButtonStyle}">
                                                <Grid Width="160">
                                                    <TextBlock Text="{loc:Localize Key=Harness_Mode_Ask}" />
                                                    <TextBlock Text="✓" HorizontalAlignment="Right" Visibility="Collapsed">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ComposerHarness.SelectedMode}" Value="{x:Static harness:SessionAgentMode.Ask}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                <Popup PlacementTarget="{Binding ElementName=KnowledgePickerButton}"
                                       Placement="Top"
                                       IsOpen="{Binding ComposerKnowledge.IsKnowledgePickerOpen, Mode=TwoWay}"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{DynamicResource Brush.Panel}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8"
                                            MinWidth="300"
                                            MaxWidth="420"
                                            MaxHeight="360">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Localize Key=Chat_SelectKnowledgeModule}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBox x:Name="KnowledgeSearchBox"
                                                     Text="{Binding ComposerKnowledge.ModuleSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"
                                                     Padding="8,6"
                                                     FontSize="12">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Chrome}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="6">
                                                                        <Grid>
                                                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" />
                                                                            <TextBlock Text="{loc:Localize Key=Chat_SearchKnowledgePlaceholder}"
                                                                                       Foreground="{DynamicResource Brush.SubtleText}"
                                                                                       FontSize="12"
                                                                                       IsHitTestVisible="False"
                                                                                       Padding="8,6"
                                                                                       Visibility="Collapsed">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="0">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsFocused" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <ListBox ItemsSource="{Binding ComposerKnowledge.FilteredModulesView}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  Margin="0,4">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding MetaText}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource Brush.SubtleText}" />
                                                            </StackPanel>
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding StopCommand}"
                                            ToolTip="{loc:Localize Key=Chat_PauseReplyTooltip}"
                                            Margin="0,0,8,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerCircleButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsComposerStopVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="■" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SendCommand}"
                                            ToolTip="{loc:Localize Key=Chat_SendTooltip}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ComposerSendButtonStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompacting}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="➤" FontSize="12" />
                                    </Button>
                                </StackPanel>
                        </Grid>
                        <!-- Knowledge chips row -->
                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    Margin="4,0,4,4"
                                    x:Name="KnowledgeChipsPanel">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ComposerKnowledge.ShowKnowledgeChips}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ItemsControl ItemsSource="{Binding ComposerKnowledge.SelectedModules}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.AccentSubtle}"
                                                BorderBrush="{DynamicResource Brush.Accent}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10,4"
                                                Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📚"
                                                           FontSize="11"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Grid.Row="4"
                                   Text="{loc:Localize Key=Chat_ComposerHint}"
                                   Foreground="{DynamicResource Brush.DisabledText}"
                                   FontSize="11"
                                   Margin="4,8,0,0" />
                    </Grid>
                </Border>
                </Grid>
            </Border>

                <!-- WPF-only gutter: keeps WebView2 HWND out of the splitter / sidebar edge -->
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Grid.RowSpan="4"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                    <Border HorizontalAlignment="Right"
                            Width="1"
                            Background="{DynamicResource Brush.Border}"
                            SnapsToDevicePixels="True" />
                </Border>
                </Grid>
    </Grid>
</UserControl>
