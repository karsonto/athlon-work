<UserControl x:Class="Athlon.Agent.App.Views.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Athlon.Agent.App.Behaviors"
             xmlns:vm="clr-namespace:Athlon.Agent.App.ViewModels"
             xmlns:loc="clr-namespace:Athlon.Agent.App.Localization"
             DataContext="{Binding Settings}">
    <ScrollViewer Padding="40,32" VerticalScrollBarVisibility="Auto" Background="{DynamicResource Brush.ChatBackground}">
                <StackPanel MaxWidth="760">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="Chat"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="{loc:Localize Key=Common_BackToChat}"
                                Content="←" />
                        <TextBlock Text="{loc:Localize Key=Settings_Title}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{loc:Localize Key=Settings_Subtitle}"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               Margin="0,0,0,24" />

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_ModelSection}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                            <TextBlock Text="{loc:Localize Key=Settings_Provider}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Model.Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="{loc:Localize Key=Settings_Endpoint}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Model.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="{loc:Localize Key=Settings_ModelNameLabel}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Model.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                            <TextBlock Text="{loc:Localize Key=Settings_MaxTokensLabel}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding ModelMaxTokensText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,6" />
                            <TextBlock Text="{loc:Localize Key=Settings_MaxTokensHint}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_EnableStreaming}" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.Model.EnableStreaming, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{loc:Localize Key=Settings_ApiKeyLabel}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <PasswordBox x:Name="ApiKeyPasswordBox"
                                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,6" />
                            <TextBlock Text="{Binding HasStoredApiKey, StringFormat=已保存 Model API Key：{0}}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       FontSize="12"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{loc:Localize Key=Settings_ApiKeyDpapiHint}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_UiSection}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14" />
                            <TextBlock Text="{loc:Localize Key=Settings_UiMemoryHint}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,0" />
                            <TextBlock Text="{loc:Localize Key=Settings_Language}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       Margin="0,14,0,6" />
                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                      SelectedValue="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      MinWidth="200"
                                      HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <ContentControl Style="{StaticResource KnowledgeNavIconStyle}"
                                                        Width="22"
                                                        Height="22"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Localize Key=Settings_KnowledgeEmbeddingTitle}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{loc:Localize Key=Settings_KnowledgeEmbeddingHint}"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{loc:Localize Key=Settings_EmbeddingEndpoint}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Knowledge.Embedding.Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,10" />
                            <TextBlock Text="{loc:Localize Key=Settings_EmbeddingModel}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <TextBox Text="{Binding Settings.Knowledge.Embedding.Model, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,10" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_VectorDimension}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding KnowledgeEmbeddingDimensionText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Localize Key=Settings_BatchSize}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding KnowledgeEmbeddingBatchSizeText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_ChunkTargetChars}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBlock Text="{loc:Localize Key=Settings_ChunkTargetCharsHint}"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                    <TextBox Text="{Binding KnowledgeChunkTargetCharsText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Localize Key=Settings_ChunkOverlapChars}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBlock Text="{loc:Localize Key=Settings_ChunkOverlapHint}"
                                               Foreground="{DynamicResource Brush.SubtleText}"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                    <TextBox Text="{Binding KnowledgeChunkOverlapCharsText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_TopK}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding KnowledgeSearchTopKText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Localize Key=Settings_MinScore}" Foreground="{DynamicResource Brush.SubtleText}" />
                                    <TextBox Text="{Binding KnowledgeSearchMinScoreText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{loc:Localize Key=Settings_EmbeddingApiKey}" Foreground="{DynamicResource Brush.SubtleText}" />
                            <PasswordBox x:Name="KnowledgeEmbeddingApiKeyPasswordBox"
                                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding KnowledgeEmbeddingApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,6" />
                            <TextBlock Text="{Binding HasStoredKnowledgeEmbeddingApiKey, StringFormat=已保存知识库 Embedding API Key：{0}}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_ContextCompactionTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_ProactiveCompaction}" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.ContextCompaction.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="{loc:Localize Key=Settings_ProactiveCompactionTooltip}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_DynamicCompaction}" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.ContextCompaction.DynamicCompaction.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="{loc:Localize Key=Settings_DynamicCompactionTooltip}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_RequestHygiene}" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.ContextCompaction.RequestHistoryHygiene.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_ToolStorm}" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource McpToggleSwitchStyle}"
                                          IsChecked="{Binding Settings.ContextCompaction.ToolStorm.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_StormThreshold}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.ContextCompaction.ToolStorm.Threshold, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_McpSearchTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox Content="{loc:Localize Key=Settings_McpSearchEnabled}"
                                      IsChecked="{Binding Settings.McpSearch.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_McpSearchMode}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.McpSearch.Mode, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_McpAutoThresholdTools}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.McpSearch.AutoThresholdToolCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Localize Key=Settings_McpAutoThresholdChars}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Settings.McpSearch.AutoThresholdSchemaChars, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_McpServersTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding McpConfigPath, StringFormat=MCP 服务从 {0} 读取；此页面仅控制每个服务是否启用。新增、删除和命令参数请直接修改 JSON 配置。}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                                                    <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource Brush.PanelAlt}">
                                                        <TextBlock Text="{Binding DisplayInitial}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15" />
                                                    </Border>
                                                    <Ellipse Width="10" Height="10"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"
                                                             Margin="0,0,-2,-2"
                                                             Stroke="{DynamicResource Brush.Border}"
                                                             StrokeThickness="2">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource Brush.DisabledText}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStatusHealthy}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Danger}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ShowStatusDot}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ToolSummary}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>

                                                <CheckBox Grid.Column="2"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{loc:Localize Key=Settings_SkillsTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding SkillsSettingsDescription}"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,0,0,14" />
                            <ItemsControl ItemsSource="{Binding Skills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SkillItemViewModel}">
                                        <Border Background="{DynamicResource Brush.Panel}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,10"
                                                Margin="0,0,0,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.55" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="36"
                                                        Height="36"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource Brush.PanelAlt}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayInitial}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               FontSize="15" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{DynamicResource Brush.SubtleText}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <CheckBox Grid.Column="2"
                                                          Style="{StaticResource McpToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{loc:Localize Key=Settings_ToolApprovalTitle}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Localize Key=Settings_ToolApprovalDescription}"
                                           Foreground="{DynamicResource Brush.SubtleText}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      IsChecked="{Binding Settings.ToolPermissions.ApprovalEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{loc:Localize Key=Settings_ToolApprovalTooltip}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{loc:Localize Key=Settings_TrainingDataTitle}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Localize Key=Settings_TrainingDataDescription}"
                                           Foreground="{DynamicResource Brush.SubtleText}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource McpToggleSwitchStyle}"
                                      IsChecked="{Binding Settings.TrainingData.Enabled, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{loc:Localize Key=Settings_TrainingDataTooltip}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,24">
                        <TextBlock Text="{Binding SettingsStatus}" Foreground="{DynamicResource Brush.SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button Content="{loc:Localize Key=Settings_SaveSettings}" Command="{Binding SaveSettingsCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </StackPanel>
    </ScrollViewer>
</UserControl>
