<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Keep the global package cache next to the repo (on the same drive as the workspace).
    Avoids restore failures when the system drive (C:) is out of space — PDFtoImage pulls large SkiaSharp native assets.
  -->
  <config>
    <add key="globalPackagesFolder" value=".nuget/packages" />
  </config>
</configuration>
